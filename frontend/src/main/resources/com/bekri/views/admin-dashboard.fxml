<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bekri.controllers.AdminDashboardController"
      styleClass="dashboard-root"
      prefWidth="1100" prefHeight="700">

    <HBox styleClass="topnav" alignment="CENTER_LEFT" spacing="12">
        <padding><Insets top="14" right="28" bottom="14" left="28"/></padding>
        <Label text="Bekri" styleClass="nav-brand"/>
        <Label text="Administration" styleClass="nav-section" HBox.hgrow="ALWAYS"/>
        <Hyperlink text="Mon profil" styleClass="nav-link" onAction="#goToProfile"/>
        <Button text="Déconnexion" styleClass="btn-logout" onAction="#handleLogout"
                style="-fx-background-color: #d0d7de, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-text-fill: #4a5568; -fx-font-size: 13px; -fx-padding: 9 18 9 18; -fx-min-height: 38; -fx-pref-height: 38; -fx-cursor: hand;"/>
    </HBox>

    <HBox VBox.vgrow="ALWAYS" minHeight="0">

        <VBox styleClass="sidebar" minWidth="200" prefWidth="200">
            <padding><Insets top="28" right="16" bottom="28" left="16"/></padding>
            <Label text="MENU" styleClass="sidebar-section-title"/>
            <Button text="👥  Utilisateurs" styleClass="sidebar-btn-active" maxWidth="Infinity"
                    onAction="#showUsers"
                    style="-fx-background-color: #009688; -fx-background-insets: 0; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: transparent; -fx-border-width: 0; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 12 28 12 28; -fx-min-height: 44; -fx-pref-height: 44; -fx-cursor: hand;"/>
        </VBox>

        <VBox HBox.hgrow="ALWAYS" styleClass="admin-content" minHeight="0" spacing="0">
            <padding><Insets top="28" right="32" bottom="28" left="32"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="Utilisateurs" styleClass="dashboard-title" HBox.hgrow="ALWAYS"/>
                <Button text="+ Ajouter" styleClass="btn-primary form-action-btn" onAction="#handleAdd"
                        style="-fx-background-color: #009688; -fx-background-insets: 0; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: transparent; -fx-border-width: 0; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 12 28 12 28; -fx-min-height: 44; -fx-pref-height: 44; -fx-cursor: hand;"/>
            </HBox>

            <HBox spacing="14">
                <VBox.margin><Insets top="18" bottom="18"/></VBox.margin>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER">
                    <Label text="👥" styleClass="stat-icon"/>
                    <Label fx:id="totalLabel" text="—" styleClass="stat-value"/>
                    <Label text="Total" styleClass="stat-label"/>
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER">
                    <Label text="👤" styleClass="stat-icon"/>
                    <Label fx:id="membresLabel" text="—" styleClass="stat-value"/>
                    <Label text="Membres" styleClass="stat-label"/>
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER">
                    <Label text="🏋️" styleClass="stat-icon"/>
                    <Label fx:id="coachsLabel" text="—" styleClass="stat-value"/>
                    <Label text="Coachs" styleClass="stat-label"/>
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER">
                    <Label text="🛡️" styleClass="stat-icon"/>
                    <Label fx:id="adminsLabel" text="—" styleClass="stat-value"/>
                    <Label text="Admins" styleClass="stat-label"/>
                </VBox>
            </HBox>

            <VBox styleClass="search-box">
                <Label text="🔍  Rechercher &amp; filtrer" styleClass="card-title"/>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <VBox.margin><Insets top="12"/></VBox.margin>
                    <TextField fx:id="searchField" styleClass="auth-field"
                               promptText="Nom, prénom ou email..." HBox.hgrow="ALWAYS"
                               style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 11 14 11 14; -fx-font-size: 13px; -fx-pref-height: 44px;"/>
                    <ComboBox fx:id="roleFilter" styleClass="auth-field" prefWidth="150"
                              promptText="Tous les rôles"
                              style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 11 14 11 14; -fx-font-size: 13px; -fx-pref-height: 44px;"/>
                    <ComboBox fx:id="statutFilter" styleClass="auth-field" prefWidth="140"
                              promptText="Tous statuts"
                              style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 11 14 11 14; -fx-font-size: 13px; -fx-pref-height: 44px;"/>
                    <Button text="Chercher" styleClass="btn-primary form-action-btn" onAction="#handleSearch"
                            style="-fx-background-color: #009688; -fx-background-insets: 0; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: transparent; -fx-border-width: 0; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 12 28 12 28; -fx-min-height: 44; -fx-pref-height: 44; -fx-cursor: hand;"/>
                    <Button text="Réinitialiser" styleClass="btn-secondary form-action-btn" onAction="#handleReset"
                            style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-text-fill: #2d3748; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 22 10 22; -fx-min-height: 42; -fx-pref-height: 42; -fx-cursor: hand;"/>
                </HBox>
            </VBox>

            <VBox spacing="0" VBox.vgrow="ALWAYS" minHeight="0">
                <VBox.margin><Insets top="16"/></VBox.margin>

                <HBox styleClass="list-header" alignment="CENTER_LEFT" spacing="12">
                    <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>
                    <Label text="UTILISATEUR" styleClass="list-col-header" HBox.hgrow="ALWAYS"/>
                    <Label text="ACTIONS" styleClass="list-col-header" minWidth="200" alignment="CENTER_RIGHT"/>
                </HBox>

                <Label fx:id="resultCountLabel" text="" styleClass="result-count">
                    <VBox.margin><Insets top="8" bottom="8" left="16"/></VBox.margin>
                </Label>

                <ListView fx:id="usersListView" VBox.vgrow="ALWAYS" minHeight="0" prefHeight="400" styleClass="users-list"/>
            </VBox>
        </VBox>
    </HBox>
</VBox>
