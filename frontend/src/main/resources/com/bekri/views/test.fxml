<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bekri.controllers.TestController"
      styleClass="test-root"
      prefWidth="800" prefHeight="700"
      alignment="TOP_CENTER">

    <!-- HEADER -->
    <VBox styleClass="test-header" alignment="CENTER">
        <padding><Insets top="32" right="40" bottom="24" left="40"/></padding>
        <Label text="Évaluation initiale de bien-être" styleClass="test-main-title"/>
        <Label text="Répondez honnêtement — vos réponses guident votre accompagnement personnalisé."
               styleClass="test-main-sub" wrapText="true"/>
        <ProgressBar fx:id="progressBar" maxWidth="500" prefHeight="8">
            <VBox.margin><Insets top="16"/></VBox.margin>
        </ProgressBar>
        <Label fx:id="pageLabel" text="Page 1 / 4" styleClass="page-label">
            <VBox.margin><Insets top="6"/></VBox.margin>
        </Label>
    </VBox>

    <!-- SECTION LABEL -->
    <Label fx:id="sectionLabel" text="🧠 Section mentale" styleClass="section-label">
        <VBox.margin><Insets top="16" left="60"/></VBox.margin>
    </Label>

    <!-- QUESTIONS -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="test-scroll">
        <VBox fx:id="questionsContainer" spacing="20" styleClass="questions-container">
            <padding><Insets top="16" right="60" bottom="16" left="60"/></padding>
        </VBox>
    </ScrollPane>

    <!-- NAVIGATION -->
    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="test-nav">
        <padding><Insets top="16" right="60" bottom="24" left="60"/></padding>
        <Button fx:id="prevBtn" text="← Précédent" styleClass="btn-secondary"
                onAction="#handlePrev"
                style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-text-fill: #2d3748; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 22 10 22; -fx-min-height: 42; -fx-pref-height: 42; -fx-cursor: hand;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="nextBtn" text="Suivant →" styleClass="btn-primary"
                onAction="#handleNext"
                style="-fx-background-color: #009688; -fx-background-insets: 0; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: transparent; -fx-border-width: 0; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 12 28 12 28; -fx-min-height: 44; -fx-pref-height: 44; -fx-cursor: hand;"/>
    </HBox>
</VBox>
