<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bekri.controllers.RegisterController"
      styleClass="auth-root"
      prefWidth="1100" prefHeight="700">

    <VBox styleClass="auth-left" HBox.hgrow="ALWAYS" maxWidth="460">
        <padding><Insets top="60" right="50" bottom="60" left="60"/></padding>
        <Label text="Bekri" styleClass="brand-logo"/>
        <Label text="Commencez votre parcours bien-être aujourd'hui"
               styleClass="auth-tagline" wrapText="true"/>
        <Label text="Rejoignez Bekri et prenez le contrôle de votre santé mentale et physique en quelques étapes."
               styleClass="auth-sub" wrapText="true"/>
        <VBox spacing="14" style="-fx-padding: 36 0 0 0;">
            <HBox styleClass="feature-row" spacing="14">
                <Label text="1" styleClass="step-number"/>
                <VBox>
                    <Label text="Créez votre compte" styleClass="feature-title"/>
                    <Label text="Inscription gratuite en 1 minute" styleClass="feature-desc"/>
                </VBox>
            </HBox>
            <HBox styleClass="feature-row" spacing="14">
                <Label text="2" styleClass="step-number"/>
                <VBox>
                    <Label text="Faites votre premier check-in" styleClass="feature-title"/>
                    <Label text="Évaluez votre bien-être du jour" styleClass="feature-desc"/>
                </VBox>
            </HBox>
            <HBox styleClass="feature-row" spacing="14">
                <Label text="3" styleClass="step-number"/>
                <VBox>
                    <Label text="Recevez vos insights IA" styleClass="feature-title"/>
                    <Label text="Analyses et conseils personnalisés" styleClass="feature-desc"/>
                </VBox>
            </HBox>
        </VBox>
    </VBox>

    <ScrollPane styleClass="auth-scroll form-scroll" HBox.hgrow="ALWAYS" fitToWidth="true">
        <VBox styleClass="auth-right form-padding" spacing="12">
            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

            <Label text="Créer un compte ✨" styleClass="auth-title"/>
            <Label text="Commencez votre parcours de bien-être gratuitement" styleClass="auth-subtitle"/>

            <Label fx:id="generalFormErrorLabel" styleClass="error-banner" wrapText="true"
                   managed="false" visible="false"/>

            <Label fx:id="errorLabel" styleClass="error-banner" wrapText="true"
                   managed="false" visible="false"/>

            <HBox spacing="6" alignment="CENTER_LEFT" styleClass="form-field-row">
                <Label text="Nom" styleClass="form-field-label"/>
                <Label text="*" styleClass="required-star"/>
            </HBox>
            <TextField fx:id="nomField" styleClass="auth-field" promptText="Votre nom"
                       style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 11 14 11 14; -fx-font-size: 13px; -fx-pref-height: 44px;"/>
            <Label fx:id="nomErrorLabel" styleClass="error-label" wrapText="true" managed="false" visible="false"/>

            <HBox spacing="6" alignment="CENTER_LEFT" styleClass="form-field-row">
                <Label text="Prénom" styleClass="form-field-label"/>
                <Label text="*" styleClass="required-star"/>
            </HBox>
            <TextField fx:id="prenomField" styleClass="auth-field" promptText="Votre prénom"
                       style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 11 14 11 14; -fx-font-size: 13px; -fx-pref-height: 44px;"/>
            <Label fx:id="prenomErrorLabel" styleClass="error-label" wrapText="true" managed="false" visible="false"/>

            <HBox spacing="6" alignment="CENTER_LEFT" styleClass="form-field-row">
                <Label text="Adresse email" styleClass="form-field-label"/>
                <Label text="*" styleClass="required-star"/>
            </HBox>
            <TextField fx:id="emailField" styleClass="auth-field" promptText="votre@email.com"
                       style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 11 14 11 14; -fx-font-size: 13px; -fx-pref-height: 44px;"/>
            <Label fx:id="emailErrorLabel" styleClass="error-label" wrapText="true" managed="false" visible="false"/>

            <HBox spacing="6" alignment="CENTER_LEFT" styleClass="form-field-row">
                <Label text="Téléphone (optionnel)" styleClass="form-field-label"/>
            </HBox>
            <TextField fx:id="telField" styleClass="auth-field" promptText="+216 XX XXX XXX"
                       style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 11 14 11 14; -fx-font-size: 13px; -fx-pref-height: 44px;"/>
            <Label fx:id="telErrorLabel" styleClass="error-label" wrapText="true" managed="false" visible="false"/>

            <HBox spacing="6" alignment="CENTER_LEFT" styleClass="form-field-row">
                <Label text="Date de naissance" styleClass="form-field-label"/>
                <Label text="*" styleClass="required-star"/>
            </HBox>
            <DatePicker fx:id="dateNaissancePicker" styleClass="auth-field" maxWidth="Infinity"
                        style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 11 14 11 14; -fx-font-size: 13px; -fx-pref-height: 44px;"/>
            <Label fx:id="dateErrorLabel" styleClass="error-label" wrapText="true" managed="false" visible="false"/>

            <Separator styleClass="section-separator">
                <VBox.margin><Insets top="8" bottom="4"/></VBox.margin>
            </Separator>

            <HBox spacing="6" alignment="CENTER_LEFT" styleClass="form-field-row">
                <Label text="Mot de passe" styleClass="form-field-label"/>
                <Label text="*" styleClass="required-star"/>
            </HBox>
            <StackPane styleClass="password-field-stack password-with-toggle" maxWidth="Infinity">
                <PasswordField fx:id="passwordField" styleClass="password-field-in-stack" maxWidth="Infinity" style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 11 46 11 14; -fx-font-size: 13px; -fx-pref-height: 44px;"/>
                <TextField fx:id="passwordPlainField" styleClass="password-field-in-stack" maxWidth="Infinity"
                           visible="false" managed="false"
                           style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 11 14 11 14; -fx-font-size: 13px; -fx-pref-height: 44px;"/>
                <HBox alignment="CENTER_RIGHT" pickOnBounds="false" maxWidth="Infinity" maxHeight="Infinity">
                    <padding><Insets right="4"/></padding>
                    <Button fx:id="passwordToggleBtn" text="👁" styleClass="eye-button password-toggle-btn password-eye-integrated"/>
                </HBox>
            </StackPane>
            <Label text="Min. 8 caractères, 1 majuscule, 1 minuscule, 1 chiffre, 1 caractère spécial (@$!%*?&amp;-_)" styleClass="field-hint"/>
            <Label fx:id="passwordErrorLabel" styleClass="error-label" wrapText="true" managed="false" visible="false"/>

            <HBox spacing="6" alignment="CENTER_LEFT" styleClass="form-field-row">
                <Label text="Confirmer le mot de passe" styleClass="form-field-label"/>
                <Label text="*" styleClass="required-star"/>
            </HBox>
            <StackPane styleClass="password-field-stack password-with-toggle" maxWidth="Infinity">
                <PasswordField fx:id="confirmPasswordField" styleClass="password-field-in-stack" maxWidth="Infinity" style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 11 46 11 14; -fx-font-size: 13px; -fx-pref-height: 44px;"/>
                <TextField fx:id="confirmPasswordPlainField" styleClass="password-field-in-stack" maxWidth="Infinity"
                           visible="false" managed="false"
                           style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 11 14 11 14; -fx-font-size: 13px; -fx-pref-height: 44px;"/>
                <HBox alignment="CENTER_RIGHT" pickOnBounds="false" maxWidth="Infinity" maxHeight="Infinity">
                    <padding><Insets right="4"/></padding>
                    <Button fx:id="confirmPasswordToggleBtn" text="👁" styleClass="eye-button password-toggle-btn password-eye-integrated"/>
                </HBox>
            </StackPane>
            <Label fx:id="confirmPasswordErrorLabel" styleClass="error-label" wrapText="true" managed="false" visible="false"/>

            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="form-field-row">
                <CheckBox fx:id="termsCheckbox" wrapText="true" text="J'accepte les conditions d'utilisation"/>
                <Label text="*" styleClass="required-star"/>
            </HBox>
            <Label fx:id="termsErrorLabel" styleClass="error-label" wrapText="true" managed="false" visible="false"/>

            <Button fx:id="registerBtn" text="Créer mon compte gratuitement"
                    styleClass="btn-primary form-submit-btn" maxWidth="Infinity"
                    onAction="#handleRegister"
                    style="-fx-background-color: #009688; -fx-background-insets: 0; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: transparent; -fx-border-width: 0; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 12 28 12 28; -fx-min-height: 44; -fx-pref-height: 44; -fx-cursor: hand;">
                <VBox.margin><Insets top="12"/></VBox.margin>
            </Button>

            <HBox alignment="CENTER" spacing="6">
                <VBox.margin><Insets top="16"/></VBox.margin>
                <Label text="Déjà un compte ?" styleClass="auth-link-text"/>
                <Hyperlink text="Se connecter" styleClass="auth-link" onAction="#goToLogin"/>
            </HBox>
        </VBox>
    </ScrollPane>
</HBox>
