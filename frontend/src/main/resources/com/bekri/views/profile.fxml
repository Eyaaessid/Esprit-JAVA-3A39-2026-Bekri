<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bekri.controllers.ProfileController"
      styleClass="dashboard-root"
      prefWidth="900" prefHeight="700">

    <!-- TOP NAV -->
    <HBox styleClass="topnav" alignment="CENTER_LEFT" spacing="12">
        <padding><Insets top="14" right="28" bottom="14" left="28"/></padding>
        <Label text="Bekri" styleClass="nav-brand" HBox.hgrow="ALWAYS"/>
        <Hyperlink text="← Retour" styleClass="nav-link" onAction="#goBack"/>
        <Button text="Déconnexion" styleClass="btn-logout" onAction="#handleLogout"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="form-scroll">
        <VBox styleClass="dashboard-content" spacing="0">
            <padding><Insets top="36" right="80" bottom="40" left="80"/></padding>

            <Label text="Mon profil" styleClass="dashboard-title"/>
            <Label text="Vos informations personnelles" styleClass="dashboard-sub"/>

            <!-- AVATAR + INFO CARD -->
            <HBox spacing="32" alignment="TOP_LEFT">
                <VBox.margin><Insets top="28"/></VBox.margin>

                <!-- Avatar -->
                <VBox styleClass="avatar-card" alignment="CENTER" spacing="12" minWidth="160">
                    <Label fx:id="avatarLabel" text="BH" styleClass="avatar-big"/>
                    <Label fx:id="fullNameLabel" text="" styleClass="profil-key"/>
                    <Label fx:id="roleLabel" text="" styleClass="role-badge"/>
                </VBox>

                <!-- Info -->
                <VBox styleClass="profil-card" HBox.hgrow="ALWAYS" spacing="16">
                    <Label text="📋 Informations utilisateur" styleClass="card-title"/>

                    <HBox spacing="16">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Prénom" styleClass="field-label"/>
                            <Label fx:id="prenomLabel" text="—" styleClass="info-value"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Nom" styleClass="field-label"/>
                            <Label fx:id="nomLabel" text="—" styleClass="info-value"/>
                        </VBox>
                    </HBox>

                    <VBox spacing="4">
                        <Label text="Email" styleClass="field-label"/>
                        <Label fx:id="emailLabel" text="—" styleClass="info-value"/>
                    </VBox>

                    <HBox spacing="16">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Téléphone" styleClass="field-label"/>
                            <Label fx:id="telLabel" text="—" styleClass="info-value"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Date de naissance" styleClass="field-label"/>
                            <Label fx:id="dateNaissanceLabel" text="—" styleClass="info-value"/>
                        </VBox>
                    </HBox>

                    <HBox spacing="16">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Statut" styleClass="field-label"/>
                            <Label fx:id="statutLabel" text="—" styleClass="info-value"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Membre depuis" styleClass="field-label"/>
                            <Label fx:id="createdAtLabel" text="—" styleClass="info-value"/>
                        </VBox>
                    </HBox>

                    <Button text="✏️  Modifier mon profil" styleClass="btn-primary form-submit-btn"
                            onAction="#goToEditProfile">
                        <VBox.margin><Insets top="8"/></VBox.margin>
                    </Button>
                </VBox>
            </HBox>
        </VBox>
    </ScrollPane>
</VBox>
