<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bekri.controllers.EditProfileController"
      styleClass="dashboard-root"
      prefWidth="900" prefHeight="700">

    <HBox styleClass="topnav" alignment="CENTER_LEFT" spacing="12">
        <padding><Insets top="14" right="28" bottom="14" left="28"/></padding>
        <Label text="Bekri" styleClass="nav-brand" HBox.hgrow="ALWAYS"/>
        <Hyperlink text="← Retour au profil" styleClass="nav-link" onAction="#goBack"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="form-scroll">
        <VBox styleClass="dashboard-content">
            <padding><Insets top="36" right="80" bottom="40" left="80"/></padding>

            <Label text="Modifier le profil" styleClass="dashboard-title"/>
            <Label text="Mettez à jour vos informations personnelles" styleClass="dashboard-sub"/>

            <Label fx:id="generalFormErrorLabel" styleClass="error-banner general-form-top" wrapText="true"
                   managed="false" visible="false"/>

            <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"
                   managed="false" visible="false"/>
            <Label fx:id="successLabel" styleClass="success-label" wrapText="true"
                   managed="false" visible="false"/>

            <VBox styleClass="profil-card" spacing="16">
                <VBox.margin><Insets top="24"/></VBox.margin>
                <Label text="✏️  Photo &amp; informations" styleClass="card-title"/>

                <StackPane fx:id="avatarStack" onMouseClicked="#onAvatarClicked" styleClass="avatar-edit-stack"
                           maxWidth="96" maxHeight="120" alignment="TOP_CENTER">
                    <VBox spacing="6" alignment="TOP_CENTER">
                        <StackPane styleClass="avatar-image-wrap" maxWidth="96" maxHeight="96">
                            <ImageView fx:id="avatarImageView" fitWidth="96" fitHeight="96"
                                       preserveRatio="true" pickOnBounds="true"/>
                            <Label fx:id="avatarInitialsLabel" text="" styleClass="profile-avatar-initials"
                                   minWidth="96" minHeight="96" maxWidth="96" maxHeight="96"
                                   alignment="CENTER"/>
                        </StackPane>
                        <Label fx:id="changePhotoHintLabel" text="Cliquer pour changer la photo"
                               styleClass="field-hint"/>
                    </VBox>
                </StackPane>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Prénom *" styleClass="field-label"/>
                        <TextField fx:id="prenomField" styleClass="auth-field"
                                   style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 11 14 11 14; -fx-font-size: 13px; -fx-pref-height: 44px;"/>
                        <Label fx:id="prenomErrorLabel" styleClass="error-label" wrapText="true"
                               managed="false" visible="false"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Nom *" styleClass="field-label"/>
                        <TextField fx:id="nomField" styleClass="auth-field"
                                   style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 11 14 11 14; -fx-font-size: 13px; -fx-pref-height: 44px;"/>
                        <Label fx:id="nomErrorLabel" styleClass="error-label" wrapText="true"
                               managed="false" visible="false"/>
                    </VBox>
                </HBox>

                <VBox spacing="6">
                    <Label text="Adresse email *" styleClass="field-label"/>
                    <TextField fx:id="emailField" styleClass="auth-field"
                               style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 11 14 11 14; -fx-font-size: 13px; -fx-pref-height: 44px;"/>
                    <Label fx:id="emailErrorLabel" styleClass="error-label" wrapText="true"
                           managed="false" visible="false"/>
                </VBox>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Téléphone" styleClass="field-label"/>
                        <TextField fx:id="telField" styleClass="auth-field" promptText="+216 XX XXX XXX"
                                   style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 11 14 11 14; -fx-font-size: 13px; -fx-pref-height: 44px;"/>
                        <Label fx:id="telErrorLabel" styleClass="error-label" wrapText="true"
                               managed="false" visible="false"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Date de naissance *" styleClass="field-label"/>
                        <DatePicker fx:id="dateNaissancePicker" maxWidth="Infinity" styleClass="auth-field"
                                    style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 11 14 11 14; -fx-font-size: 13px; -fx-pref-height: 44px;"/>
                        <Label fx:id="dateErrorLabel" styleClass="error-label" wrapText="true"
                               managed="false" visible="false"/>
                    </VBox>
                </HBox>

                <Button fx:id="togglePasswordSectionBtn" text="Changer le mot de passe"
                        styleClass="btn-secondary form-action-btn" onAction="#togglePasswordSection"
                        style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-text-fill: #2d3748; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 22 10 22; -fx-min-height: 42; -fx-pref-height: 42; -fx-cursor: hand;"/>

                <VBox fx:id="passwordSection" spacing="12" managed="false" visible="false">
                    <Label text="Nouveau mot de passe" styleClass="field-label"/>
                    <StackPane styleClass="password-field-stack password-with-toggle" maxWidth="Infinity">
                        <PasswordField fx:id="newPasswordField"
                                       styleClass="password-field-in-stack" maxWidth="Infinity" style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 11 46 11 14; -fx-font-size: 13px; -fx-pref-height: 44px;"/>
                        <TextField fx:id="newPasswordPlainField"
                                   styleClass="password-field-in-stack" maxWidth="Infinity"
                                   visible="false" managed="false"
                                   style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 11 14 11 14; -fx-font-size: 13px; -fx-pref-height: 44px;"/>
                        <HBox alignment="CENTER_RIGHT" pickOnBounds="false" maxWidth="Infinity" maxHeight="Infinity">
                            <padding><Insets right="4"/></padding>
                            <Button fx:id="newPasswordToggleBtn" text="👁"
                                    styleClass="eye-button password-toggle-btn password-eye-integrated"/>
                        </HBox>
                    </StackPane>
                    <Label fx:id="newPasswordErrorLabel" styleClass="error-label" wrapText="true"
                           managed="false" visible="false"/>

                    <Label text="Confirmer le mot de passe" styleClass="field-label"/>
                    <StackPane styleClass="password-field-stack password-with-toggle" maxWidth="Infinity">
                        <PasswordField fx:id="confirmNewPasswordField"
                                       styleClass="password-field-in-stack" maxWidth="Infinity" style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 11 46 11 14; -fx-font-size: 13px; -fx-pref-height: 44px;"/>
                        <TextField fx:id="confirmNewPasswordPlainField"
                                   styleClass="password-field-in-stack" maxWidth="Infinity"
                                   visible="false" managed="false"
                                   style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 11 14 11 14; -fx-font-size: 13px; -fx-pref-height: 44px;"/>
                        <HBox alignment="CENTER_RIGHT" pickOnBounds="false" maxWidth="Infinity" maxHeight="Infinity">
                            <padding><Insets right="4"/></padding>
                            <Button fx:id="confirmNewPasswordToggleBtn" text="👁"
                                    styleClass="eye-button password-toggle-btn password-eye-integrated"/>
                        </HBox>
                    </StackPane>
                    <Label fx:id="confirmNewPasswordErrorLabel" styleClass="error-label" wrapText="true"
                           managed="false" visible="false"/>
                </VBox>
            </VBox>

            <HBox spacing="12" alignment="CENTER_RIGHT">
                <VBox.margin><Insets top="20"/></VBox.margin>
                <Button fx:id="resetBtn" text="Réinitialiser" styleClass="btn-secondary form-action-btn"
                        onAction="#handleReset"
                        style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-text-fill: #2d3748; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 22 10 22; -fx-min-height: 42; -fx-pref-height: 42; -fx-cursor: hand;"/>
                <Button fx:id="saveBtn" text="✓  Enregistrer les modifications"
                        styleClass="btn-primary form-submit-btn" onAction="#handleSave"
                        style="-fx-background-color: #009688; -fx-background-insets: 0; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: transparent; -fx-border-width: 0; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 12 28 12 28; -fx-min-height: 44; -fx-pref-height: 44; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </ScrollPane>
</VBox>
