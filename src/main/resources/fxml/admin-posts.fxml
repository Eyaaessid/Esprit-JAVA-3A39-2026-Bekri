<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.user.ui.AdminPostsController"
            styleClass="page-bg"
            prefWidth="1100" prefHeight="700">
    <stylesheets>
        <URL value="@../css/bekri.css"/>
    </stylesheets>
    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="16">
            <Button text="← Retour" styleClass="btn-ghost" onAction="#handleBack"/>
            <Label text="Gestion des posts" styleClass="top-bar-title"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox spacing="16" style="-fx-background-color: #f4f6f9; -fx-padding: 24;">

                <!-- ── Stat cards ── -->
                <HBox spacing="14">
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="4"
                          style="-fx-background-color: white; -fx-background-radius: 12;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);
                                 -fx-padding: 16 24;">
                        <Label text="📝" style="-fx-font-size: 22px;"/>
                        <Label fx:id="totalPostsLabel" text="—"
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                        <Label text="Total Posts"
                               style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
                    </VBox>
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="4"
                          style="-fx-background-color: white; -fx-background-radius: 12;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);
                                 -fx-padding: 16 24;">
                        <Label text="💭" style="-fx-font-size: 22px;"/>
                        <Label fx:id="totalCommentsLabel" text="—"
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                        <Label text="Total Comments"
                               style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
                    </VBox>
                </HBox>

                <!-- ── Search & filter bar ── -->
                <HBox spacing="12" alignment="CENTER_LEFT"
                      style="-fx-background-color: white; -fx-background-radius: 10;
                             -fx-padding: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 1);">
                    <TextField fx:id="searchField" promptText="🔍  Rechercher un post..."
                               HBox.hgrow="ALWAYS"
                               style="-fx-background-color: #f4f6f9; -fx-background-radius: 8;
                                      -fx-border-color: transparent; -fx-padding: 10 14; -fx-font-size: 13px;"/>
                    <ComboBox fx:id="categoryFilter" promptText="Toutes catégories" prefWidth="150"
                              style="-fx-background-color: #f4f6f9; -fx-background-radius: 8;
                                     -fx-border-color: transparent; -fx-padding: 6 10;"/>
                    <ComboBox fx:id="sortFilter" promptText="Trier par" prefWidth="120"
                              style="-fx-background-color: #f4f6f9; -fx-background-radius: 8;
                                     -fx-border-color: transparent; -fx-padding: 6 10;"/>
                    <Button text="Chercher" onAction="#handleSearch"
                            style="-fx-background-color: #1e3a5f; -fx-text-fill: white;
                                   -fx-background-radius: 8; -fx-padding: 10 20;
                                   -fx-font-weight: bold; -fx-cursor: hand;"/>
                    <Button text="Réinitialiser" onAction="#handleReset"
                            style="-fx-background-color: #ecf0f1; -fx-text-fill: #555;
                                   -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
                </HBox>

                <!-- ── Result count ── -->
                <Label fx:id="resultCountLabel" text=""
                       style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d; -fx-padding: 0 4;"/>

                <!-- ── Posts list ── -->
                <TableView fx:id="postsTable" VBox.vgrow="ALWAYS" minHeight="0" prefHeight="400"
                           style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <columns>
                        <TableColumn fx:id="postIdColumn" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="postAuthorColumn" text="Auteur" prefWidth="150"/>
                        <TableColumn fx:id="postTitleColumn" text="Titre" prefWidth="200"/>
                        <TableColumn fx:id="postCategoryColumn" text="Catégorie" prefWidth="120"/>
                        <TableColumn fx:id="postLikesColumn" text="Likes" prefWidth="80"/>
                        <TableColumn fx:id="postCommentsColumn" text="Commentaires" prefWidth="100"/>
                        <TableColumn fx:id="postCreatedColumn" text="Créé le" prefWidth="150"/>
                    </columns>
                </TableView>

                <!-- ── Empty state ── -->
                <Label fx:id="emptyStateLabel" text="Aucun post trouvé."
                       visible="false" managed="false"
                       alignment="CENTER" maxWidth="Infinity"
                       style="-fx-text-fill: #95a5a6; -fx-font-size: 14px; -fx-padding: 40 0 0 0;"/>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>