<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.community.ui.PostDetailsController"
            maxWidth="Infinity" maxHeight="Infinity">
    <stylesheets>
        <URL value="@../../css/app.css"/>
        <URL value="@../../css/community.css"/>
    </stylesheets>
    <ScrollPane fitToWidth="true"
                fitToHeight="false"
                hbarPolicy="NEVER"
                vbarPolicy="AS_NEEDED"
                maxWidth="Infinity"
                maxHeight="Infinity"
                styleClass="scroll-pane"
                AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
                AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        <content>
            <VBox spacing="16" fillWidth="true">
                <padding>
                    <Insets top="16" right="24" bottom="24" left="24"/>
                </padding>
                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="top-bar">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label styleClass="top-bar-title" text="Détail du post"/>
                        <Label styleClass="muted" text="Publication et interactions"/>
                    </VBox>
                    <Button onAction="#handleBackToDashboard" styleClass="btn-ghost" text="Accueil"/>
                    <Button onAction="#handleBackToPosts" styleClass="btn-ghost" text="Retour aux posts"/>
                    <Button onAction="#handleOpenComments" styleClass="btn-primary" text="Commentaires"/>
                </HBox>

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <VBox spacing="6">
                        <Label styleClass="section-label" text="Utilisateur"/>
                        <ComboBox fx:id="currentUserComboBox" prefWidth="260"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="likeButton" onAction="#handleToggleLike" styleClass="btn-secondary" text="Like"/>
                    <Button fx:id="saveButton" onAction="#handleToggleSave" styleClass="btn-secondary" text="Save"/>
                    <Button fx:id="editPostButton" disable="true" onAction="#handleEditPost" styleClass="btn-ghost" text="Modifier"/>
                    <Button fx:id="deletePostButton" disable="true" onAction="#handleDeletePost" styleClass="btn-danger" text="Supprimer"/>
                </HBox>

                <VBox spacing="14" styleClass="detail-card">
                    <padding>
                        <Insets top="18" right="18" bottom="18" left="18"/>
                    </padding>
                    <Label fx:id="selectedPostTitleLabel" styleClass="detail-title" text="Select a post"/>
                    <Label fx:id="selectedPostMetaLabel" styleClass="muted-label" text="Post details"/>
                    <HBox spacing="8">
                        <Label fx:id="selectedPostCategoryLabel" styleClass="pill-label pill-neutral" text="No category"/>
                        <Label fx:id="selectedPostStatsLabel" styleClass="muted-label" text="0 likes - 0 comments"/>
                    </HBox>
                    <Label fx:id="selectedPostRiskLabel" styleClass="risk-label" text="Risk: n/a"/>
                    <ImageView fx:id="postImageView" fitHeight="260" fitWidth="520" pickOnBounds="true" preserveRatio="true"/>
                    <Separator/>
                    <Label fx:id="selectedPostContentLabel" styleClass="detail-content" text="Post content" wrapText="true"/>
                </VBox>
            </VBox>
        </content>
    </ScrollPane>
</AnchorPane>
