<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.user.ui.ResetPasswordController"
            prefWidth="960" prefHeight="640">
    <center>
        <VBox alignment="CENTER" spacing="18" styleClass="auth-right-panel">
            <padding><Insets top="48" right="48" bottom="48" left="48"/></padding>

            <VBox styleClass="auth-form-card" spacing="14" maxWidth="520">
                <VBox spacing="4">
                    <Label text="Réinitialiser le mot de passe" styleClass="auth-title"/>
                </VBox>
                <Separator/>

                <VBox spacing="10">
                    <TextField fx:id="tokenField" promptText="Collez le code reçu par email" styleClass="text-field"/>
                    <PasswordField fx:id="passwordField" promptText="Nouveau mot de passe (min. 6 caractères)" styleClass="password-field"/>
                    <PasswordField fx:id="confirmPasswordField" promptText="Confirmer le mot de passe" styleClass="password-field"/>
                </VBox>

                <Label fx:id="statusLabel" wrapText="true" managed="false" visible="false" styleClass="error-label"/>

                <Button fx:id="resetButton" text="Réinitialiser" onAction="#handleReset" maxWidth="Infinity" styleClass="btn-primary"/>

                <Hyperlink fx:id="backToLoginLink" text="← Retour à la connexion" onAction="#goToLogin"/>
            </VBox>
        </VBox>
    </center>
</BorderPane>

