<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.user.ui.UserDashboardController"
            prefWidth="1100" prefHeight="700" styleClass="page-bg">

    <stylesheets>
        <URL value="@../css/app.css"/>
        <URL value="@../css/weather.css"/>
    </stylesheets>

    <!-- ══ SIDEBAR ══════════════════════════════════════════════════ -->
    <left>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" maxHeight="Infinity" styleClass="sidebar-scroll">
            <content>
                <VBox styleClass="sidebar" minHeight="0" maxHeight="Infinity">
            <VBox styleClass="sidebar-logo-box" spacing="2">
                <Label text="bekri"                     styleClass="sidebar-logo"/>
                <Label text="Bien-être &amp; Objectifs" styleClass="sidebar-logo-sub"/>
            </VBox>

            <VBox styleClass="sidebar-nav-box" spacing="0">
                <Label text="MENU" styleClass="sidebar-section-label"/>
                <Button text="🏠  Accueil"             styleClass="sidebar-btn-active" onAction="#handleAccueil"/>
                <Button text="🎯  Mes Objectifs"       styleClass="sidebar-btn"        onAction="#handleObjectifs"/>
                <Button text="✅  Daily Check-in"      styleClass="sidebar-btn"        onAction="#handleDailyCheckIn"/>
                <Button text="📅  Plan de la semaine"  styleClass="sidebar-btn"        onAction="#handleWeekPlan"/>
                <Button text="📈  Weekly Insights"     styleClass="sidebar-btn"        onAction="#handleWeeklyInsights"/>
                <Button text="💬  Posts"               styleClass="sidebar-btn"        onAction="#handleCommunity"/>
                <Button text="🤖  Chatbot"             styleClass="sidebar-btn"        onAction="#handleChatBot"/>
                <Button text="🧠  Test Psychologique"  styleClass="sidebar-btn"        onAction="#handleTest"/>
                <Button text="📊  Mon Profil Psy"      styleClass="sidebar-btn"        onAction="#handleProfilPsy"/>
                <Button text="📝  Test Mental" styleClass="sidebar-btn" onAction="#handleTestMental"/>

                <Button text="👤  Mon Profil"          styleClass="sidebar-btn"        onAction="#handleProfil"/>
                <Label text="EVENTS" styleClass="sidebar-section-label"/>
                <Button text="📅  Événements" styleClass="sidebar-btn" onAction="#handleEvenements"/>
                <Button text="🎫  Mes Participations" styleClass="sidebar-btn" onAction="#handleMesParticipations"/>
                <Button text="❤️  Mes Favoris" styleClass="sidebar-btn" onAction="#handleMesFavoris"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox styleClass="sidebar-divider">
                <Button text="⎋  Déconnexion" styleClass="sidebar-logout" onAction="#handleLogout"/>
            </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </left>

    <!-- ══ MAIN CONTENT ═════════════════════════════════════════════ -->
    <center>
        <VBox maxHeight="Infinity" styleClass="dashboard-main-shell">
            <HBox styleClass="top-bar" alignment="CENTER_RIGHT" spacing="12">
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Profil" styleClass="icon-btn" onAction="#openProfile">
                    <tooltip><Tooltip text="Mon Profil"/></tooltip>
                </Button>
                <Button text="Deconnexion" styleClass="icon-btn" onAction="#logout">
                    <tooltip><Tooltip text="Deconnexion"/></tooltip>
                </Button>
            </HBox>
            <ScrollPane fitToWidth="true" fitToHeight="false" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" maxWidth="Infinity" maxHeight="Infinity" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
            <VBox spacing="24">
                <padding><Insets top="32" right="36" bottom="32" left="36"/></padding>

                <!-- ── Welcome card ──────────────────────────────────────── -->
                <HBox styleClass="welcome-card" alignment="CENTER_LEFT" spacing="16">
                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <Label fx:id="welcomeLabel"      text="Bonjour 👋"   styleClass="welcome-greeting"/>
                        <Label fx:id="dateLabel"         text="Aujourd'hui"  styleClass="welcome-date"/>
                        <Label text="Prenez soin de vous aujourd'hui. Votre bien-être compte."
                               styleClass="welcome-tagline"/>
                        <Label fx:id="roleSubtitleLabel" text=""             styleClass="welcome-date"/>
                    </VBox>
                    <Label text="💙" style="-fx-font-size: 48px; -fx-text-fill: #FFFFFF; -fx-opacity: 0.6;"/>
                </HBox>

                <!-- ── Quick-access cards ────────────────────────────────── -->
                <VBox spacing="16">
                    <Label text="Accès rapide" styleClass="section-title"/>
                    <FlowPane hgap="16" vgap="16">

                        <VBox styleClass="quick-card" onMouseClicked="#handleObjectifsClick"
                              alignment="CENTER" spacing="8">
                            <Label text="🎯" styleClass="quick-card-icon"/>
                            <Label text="Mes Objectifs"       styleClass="quick-card-title"/>
                            <Label text="Gérer vos objectifs" styleClass="quick-card-sub"/>
                        </VBox>

                        <VBox styleClass="quick-card" onMouseClicked="#handleDailyCheckInClick"
                              alignment="CENTER" spacing="8">
                            <Label text="✅" styleClass="quick-card-icon"/>
                            <Label text="Daily Check-in"  styleClass="quick-card-title"/>
                            <Label text="Suivi quotidien" styleClass="quick-card-sub"/>
                        </VBox>

                        <VBox styleClass="quick-card" onMouseClicked="#handleWeekPlanClick"
                              alignment="CENTER" spacing="8">
                            <Label text="📅" styleClass="quick-card-icon"/>
                            <Label text="Plan semaine"          styleClass="quick-card-title"/>
                            <Label text="Organiser la semaine"  styleClass="quick-card-sub"/>
                        </VBox>

                        <VBox styleClass="quick-card" onMouseClicked="#handleWeeklyInsightsClick"
                              alignment="CENTER" spacing="8">
                            <Label text="📈" styleClass="quick-card-icon"/>
                            <Label text="Weekly Insights"       styleClass="quick-card-title"/>
                            <Label text="Bilan &amp; tendances" styleClass="quick-card-sub"/>
                        </VBox>

                        <VBox styleClass="quick-card" onMouseClicked="#handleCommunityClick"
                              alignment="CENTER" spacing="8">
                            <Label text="ðŸ’¬" styleClass="quick-card-icon"/>
                            <Label text="Posts" styleClass="quick-card-title"/>
                            <Label text="Voir la communaute" styleClass="quick-card-sub"/>
                        </VBox>

                        <VBox styleClass="quick-card" onMouseClicked="#handleChatBotClick"
                              alignment="CENTER" spacing="8">
                            <Label text="🤖" styleClass="quick-card-icon"/>
                            <Label text="Chatbot"               styleClass="quick-card-title"/>
                            <Label text="Parler &amp; conseils" styleClass="quick-card-sub"/>
                        </VBox>

                        <VBox styleClass="quick-card" onMouseClicked="#handleTestClick"
                              alignment="CENTER" spacing="8">
                            <Label text="🧠" styleClass="quick-card-icon"/>
                            <Label text="Test Psy"              styleClass="quick-card-title"/>
                            <Label text="Évaluation bien-être"  styleClass="quick-card-sub"/>
                        </VBox>

                        <VBox styleClass="quick-card" onMouseClicked="#handleProfilPsyClick"
                              alignment="CENTER" spacing="8">
                            <Label text="📊" styleClass="quick-card-icon"/>
                            <Label text="Mon Profil Psy"    styleClass="quick-card-title"/>
                            <Label text="Voir mes résultats" styleClass="quick-card-sub"/>
                        </VBox>
                        <VBox styleClass="quick-card" onMouseClicked="#handleTestMentalClick"
                              alignment="CENTER" spacing="8">
                            <Label text="Test" styleClass="quick-card-icon"/>
                            <Label text="Tests Mentaux" styleClass="quick-card-title"/>
                            <Label text="Exercices et passage" styleClass="quick-card-sub"/>
                        </VBox>

                        <VBox styleClass="quick-card" onMouseClicked="#handleProfilClick"
                              alignment="CENTER" spacing="8">
                            <Label text="👤" styleClass="quick-card-icon"/>
                            <Label text="Mon Profil"       styleClass="quick-card-title"/>
                            <Label text="Mes informations" styleClass="quick-card-sub"/>
                        </VBox>

                    </FlowPane>
                </VBox>

                <!-- ══════════════════════════════════════════════════════════
                     WEATHER CARD  (redesigned)
                     fx:id="weatherCardBox" → controller applies condition class
                     ══════════════════════════════════════════════════════════ -->
                <VBox fx:id="weatherCardBox" styleClass="weather-card-root" spacing="0">

                    <!-- ── Top header band: emoji + city/summary + badge ─── -->
                    <HBox styleClass="weather-header-band" alignment="CENTER_LEFT" spacing="16">

                        <!-- Big animated-feel emoji -->
                        <Label fx:id="lblWeatherEmoji"
                               text="🌤️"
                               styleClass="weather-emoji-big"/>

                        <!-- City + summary text -->
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label fx:id="lblWeatherTitle"
                                   text="Météo"
                                   styleClass="weather-title"/>
                            <Label fx:id="lblWeatherSummary"
                                   text="Chargement en cours..."
                                   styleClass="weather-subtitle"
                                   wrapText="true"/>
                        </VBox>

                        <!-- Condition pill badge -->
                        <Label fx:id="lblWeatherBadge"
                               text=""
                               styleClass="weather-badge weather-default"/>
                    </HBox>

                    <!-- ── Stat row: Temp / Humidity / Wind ──────────────── -->
                    <HBox styleClass="weather-stats-row" spacing="14" alignment="CENTER_LEFT">
                        <padding><Insets top="16" bottom="16"/></padding>

                        <!-- Temperature -->
                        <VBox styleClass="weather-stat-box weather-stat-temp"
                              alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="🌡️" styleClass="weather-stat-icon"/>
                            <Label text="TEMPÉRATURE" styleClass="weather-stat-label"/>
                            <Label fx:id="lblTemp" text="—" styleClass="weather-stat-value"/>
                        </VBox>

                        <!-- Humidity -->
                        <VBox styleClass="weather-stat-box weather-stat-hum"
                              alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="💧" styleClass="weather-stat-icon"/>
                            <Label text="HUMIDITÉ" styleClass="weather-stat-label"/>
                            <Label fx:id="lblHumidity" text="—" styleClass="weather-stat-value"/>
                        </VBox>

                        <!-- Wind -->
                        <VBox styleClass="weather-stat-box weather-stat-wind"
                              alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="💨" styleClass="weather-stat-icon"/>
                            <Label text="VENT" styleClass="weather-stat-label"/>
                            <Label fx:id="lblWind" text="—" styleClass="weather-stat-value"/>
                        </VBox>

                    </HBox>

                    <!-- ── Subtle divider ────────────────────────────────── -->
                    <HBox styleClass="weather-divider">
                        <Region prefHeight="1"/>
                    </HBox>

                    <!-- ── Tips section ──────────────────────────────────── -->
                    <VBox styleClass="weather-tips-section" spacing="10">
                        <padding><Insets top="14"/></padding>

                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="💡" style="-fx-font-size: 15px;"/>
                            <Label text="Conseils bien-être du jour"
                                   styleClass="weather-tips-title"/>
                        </HBox>

                        <!-- Tips injected dynamically by controller as .weather-tip-row HBoxes -->
                        <VBox fx:id="weatherTipsContainer" spacing="8"/>

                    </VBox>

                    <!-- ── Loading / error status ────────────────────────── -->
                    <Label fx:id="lblWeatherStatus"
                           text=""
                           styleClass="weather-status-label"
                           wrapText="true"
                           visible="false"
                           managed="false">
                        <VBox.margin><Insets left="22" right="22" bottom="14"/></VBox.margin>
                    </Label>

                </VBox>
                <!-- ══ END WEATHER CARD ════════════════════════════════════ -->

            </VBox>
            </ScrollPane>
        </VBox>
    </center>

</BorderPane>
