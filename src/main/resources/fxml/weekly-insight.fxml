<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.suivi.ui.WeeklyInsightController"
            prefWidth="1200" prefHeight="720"
            styleClass="page-bg">
    <stylesheets>
        <URL value="@../css/bekri.css"/>
        <URL value="@../css/weather.css"/>
        <URL value="@../css/weekly-insight.css"/>
    </stylesheets>

    <!-- ══ SIDEBAR ══════════════════════════════════════════════════ -->
    <left>
        <VBox styleClass="sidebar">
            <VBox styleClass="sidebar-logo-box" spacing="2">
                <Label text="bekri" styleClass="sidebar-logo"/>
                <Label text="Bien-être &amp; Objectifs" styleClass="sidebar-logo-sub"/>
            </VBox>

            <VBox styleClass="sidebar-nav-box" spacing="0">
                <Label text="MENU" styleClass="sidebar-section-label"/>
                <Button text="🏠  Accueil"             styleClass="sidebar-btn" onAction="#handleAccueil"/>
                <Button text="🎯  Mes Objectifs"       styleClass="sidebar-btn" onAction="#handleObjectifs"/>
                <Button text="✅  Daily Check-in"      styleClass="sidebar-btn" onAction="#handleDailyCheckIn"/>
                <Button text="📅  Plan de la semaine"  styleClass="sidebar-btn" onAction="#handleWeekPlan"/>
                <Button text="📈  Weekly Insights"     styleClass="sidebar-btn" onAction="#handleWeeklyInsights"/>
                <Button text="🤖  Chatbot"             styleClass="sidebar-btn" onAction="#handleChatBot"/>
                <Button text="🧠  Test Psychologique"  styleClass="sidebar-btn" onAction="#handleTest"/>
                <Button text="📊  Mon Profil Psy"      styleClass="sidebar-btn" onAction="#handleProfilPsy"/>
                <Button text="👤  Mon Profil"          styleClass="sidebar-btn" onAction="#handleProfil"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox styleClass="sidebar-divider">
                <Button text="⎋  Déconnexion" styleClass="sidebar-logout" onAction="#handleLogout"/>
            </VBox>
        </VBox>
    </left>

    <!-- ══ MAIN CONTENT ═════════════════════════════════════════════ -->
    <center>
        <VBox>

            <!-- ── Top bar ──────────────────────────────────────────── -->
            <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="12">
                <Label text="Insights hebdomadaires" styleClass="top-bar-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="periodLabel" text="Période" styleClass="sym-topbar-period page-subtitle"/>
                <Button text="📄  Télécharger PDF" onAction="#handleExportPdf"
                        style="-fx-background-color: linear-gradient(to right,#14b8a6,#0d9488);
                               -fx-text-fill: white; -fx-background-radius: 10;
                               -fx-padding: 9 18 9 18; -fx-font-size: 13px;
                               -fx-font-weight: 700; -fx-cursor: hand;
                               -fx-border-color: transparent;"/>
            </HBox>

            <ScrollPane fx:id="rootScroll" fitToWidth="true" styleClass="sym-scroll" VBox.vgrow="ALWAYS">
                <content>
                    <VBox spacing="20" styleClass="sym-content">
                        <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>

                        <!-- ── Empty state ────────────────────────────────── -->
                        <VBox fx:id="emptyStateBox" visible="false" managed="false"
                              spacing="16" styleClass="sym-empty" alignment="CENTER">
                            <Label text="📊  Aucune donnée disponible" styleClass="sym-empty-title"/>
                            <Label text="Vous n'avez pas encore rempli de check-in cette semaine. Commencez dès aujourd'hui !"
                                   wrapText="true" styleClass="sym-empty-text" maxWidth="480"/>
                            <Button text="✅  Faire mon check-in" onAction="#handleCheckIn"
                                    style="-fx-background-color: linear-gradient(to right,#14b8a6,#0d9488);
                                           -fx-text-fill: white; -fx-background-radius: 12;
                                           -fx-padding: 12 24 12 24; -fx-font-size:14px;
                                           -fx-font-weight:700; -fx-cursor:hand;
                                           -fx-border-color:transparent;"/>
                        </VBox>

                        <!-- ── All data content ───────────────────────────── -->
                        <VBox fx:id="contentSections" spacing="20">

                            <!-- ── ROW 1: Stat cards ─────────────────────── -->
                            <HBox spacing="14">
                                <!-- Jours complétés -->
                                <VBox spacing="6" HBox.hgrow="ALWAYS"
                                      style="-fx-background-color:#0a1628;
                                             -fx-background-radius:16;
                                             -fx-padding:20;
                                             -fx-border-color:rgba(20,184,166,0.35);
                                             -fx-border-radius:16;
                                             -fx-border-width:1;">
                                    <Label text="JOURS COMPLÉTÉS"
                                           style="-fx-text-fill:#475569;-fx-font-size:10px;-fx-font-weight:700;"/>
                                    <Label fx:id="daysFilledLabel" text="0 / 7"
                                           style="-fx-font-size:28px;-fx-font-weight:800;-fx-text-fill:#14b8a6;"/>
                                    <Label text="Cette semaine"
                                           style="-fx-text-fill:#334155;-fx-font-size:12px;"/>
                                    <Label text="✓ En bonne voie"
                                           style="-fx-background-color:rgba(20,184,166,0.12);
                                                  -fx-text-fill:#14b8a6;
                                                  -fx-background-radius:20;
                                                  -fx-padding:3 10 3 10;
                                                  -fx-font-size:11px;-fx-font-weight:600;"/>
                                </VBox>

                                <!-- Meilleur jour -->
                                <VBox spacing="6" HBox.hgrow="ALWAYS"
                                      style="-fx-background-color:#0a1628;
                                             -fx-background-radius:16;
                                             -fx-padding:20;
                                             -fx-border-color:rgba(245,158,11,0.35);
                                             -fx-border-radius:16;
                                             -fx-border-width:1;">
                                    <Label text="MEILLEUR JOUR"
                                           style="-fx-text-fill:#475569;-fx-font-size:10px;-fx-font-weight:700;"/>
                                    <Label fx:id="bestDayLabel" text="—"
                                           style="-fx-font-size:22px;-fx-font-weight:800;-fx-text-fill:#f59e0b;"/>
                                    <Label fx:id="bestHighlightLabel" text="—"
                                           style="-fx-text-fill:#334155;-fx-font-size:12px;"/>
                                    <Label text="↑ Top journée"
                                           style="-fx-background-color:rgba(245,158,11,0.12);
                                                  -fx-text-fill:#f59e0b;
                                                  -fx-background-radius:20;
                                                  -fx-padding:3 10 3 10;
                                                  -fx-font-size:11px;-fx-font-weight:600;"/>
                                </VBox>

                                <!-- Jour difficile -->
                                <VBox spacing="6" HBox.hgrow="ALWAYS"
                                      style="-fx-background-color:#0a1628;
                                             -fx-background-radius:16;
                                             -fx-padding:20;
                                             -fx-border-color:rgba(239,68,68,0.35);
                                             -fx-border-radius:16;
                                             -fx-border-width:1;">
                                    <Label text="JOUR DIFFICILE"
                                           style="-fx-text-fill:#475569;-fx-font-size:10px;-fx-font-weight:700;"/>
                                    <Label fx:id="worstDayLabel" text="—"
                                           style="-fx-font-size:22px;-fx-font-weight:800;-fx-text-fill:#ef4444;"/>
                                    <Label fx:id="worstHighlightLabel" text="—"
                                           style="-fx-text-fill:#334155;-fx-font-size:12px;"/>
                                    <Label text="↓ À surveiller"
                                           style="-fx-background-color:rgba(239,68,68,0.12);
                                                  -fx-text-fill:#ef4444;
                                                  -fx-background-radius:20;
                                                  -fx-padding:3 10 3 10;
                                                  -fx-font-size:11px;-fx-font-weight:600;"/>
                                </VBox>

                                <!-- Score global -->
                                <VBox spacing="6" HBox.hgrow="ALWAYS"
                                      style="-fx-background-color:#0a1628;
                                             -fx-background-radius:16;
                                             -fx-padding:20;
                                             -fx-border-color:rgba(99,102,241,0.35);
                                             -fx-border-radius:16;
                                             -fx-border-width:1;">
                                    <Label text="SCORE MOYEN GLOBAL"
                                           style="-fx-text-fill:#475569;-fx-font-size:10px;-fx-font-weight:700;"/>
                                    <Label fx:id="globalAvgLabel" text="—"
                                           style="-fx-font-size:28px;-fx-font-weight:800;-fx-text-fill:#818cf8;"/>
                                    <Label text="Toutes catégories"
                                           style="-fx-text-fill:#334155;-fx-font-size:12px;"/>
                                    <Label text="⚡ En progression"
                                           style="-fx-background-color:rgba(99,102,241,0.12);
                                                  -fx-text-fill:#818cf8;
                                                  -fx-background-radius:20;
                                                  -fx-padding:3 10 3 10;
                                                  -fx-font-size:11px;-fx-font-weight:600;"/>
                                </VBox>
                            </HBox>

                            <!-- ── ROW 2: Encouragement strip ────────────── -->
                            <HBox styleClass="sym-encourage" spacing="12" alignment="CENTER_LEFT">
                                <Label text="💪" style="-fx-font-size:20px;"/>
                                <Label fx:id="encouragementLabel"
                                       text="Vous progressez doucement — chaque jour compte."
                                       styleClass="sym-encourage-title"
                                       wrapText="true" HBox.hgrow="ALWAYS"/>
                            </HBox>

                            <!-- ── ROW 3: AI Recommendations panel ───────── -->
                            <VBox styleClass="sym-reco-panel" spacing="16">
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label text="✨" style="-fx-font-size:18px;"/>
                                    <Label text="Recommandations IA personnalisées"
                                           styleClass="sym-reco-title section-header"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="aiStatusLabel"
                                           text="Chargement IA..."
                                           styleClass="ai-status-label"/>
                                    <Label text="Basées sur vos données"
                                           styleClass="sym-reco-subtitle"/>
                                </HBox>
                                <HBox fx:id="recommendationBox" spacing="14"/>
                            </VBox>

                            <!-- ── ROW 4: Donut + Bar charts ─────────────── -->
                            <HBox spacing="16">

                                <!-- Donut -->
                                <VBox styleClass="sym-card" spacing="10" HBox.hgrow="ALWAYS">
                                    <Label text="SCORE MOYEN TOUTES CATÉGORIES"
                                           styleClass="sym-card-title card-title"/>
                                    <StackPane styleClass="sym-donut-wrap">
                                        <PieChart fx:id="globalPieChart"
                                                  legendVisible="false" labelsVisible="false"
                                                  styleClass="sym-donut" prefHeight="210"/>
                                        <VBox alignment="CENTER" spacing="2">
                                            <Label fx:id="donutCenterLabel" text="0%"
                                                   styleClass="sym-donut-center"/>
                                            <Label text="global"
                                                   style="-fx-text-fill:#475569;-fx-font-size:11px;"/>
                                        </VBox>
                                    </StackPane>
                                </VBox>

                                <!-- Bar chart -->
                                <VBox styleClass="sym-card" spacing="10" HBox.hgrow="ALWAYS">
                                    <Label text="SCORES PAR CATÉGORIE (0–100%)"
                                           styleClass="sym-card-title card-title"/>
                                    <BarChart fx:id="categoryBarChart" animated="false"
                                              legendVisible="false" prefHeight="230"
                                              style="-fx-background-color:transparent;">
                                        <xAxis><CategoryAxis
                                                style="-fx-tick-label-fill:#64748b;-fx-font-size:11px;"/></xAxis>
                                        <yAxis>
                                            <NumberAxis lowerBound="0" upperBound="100"
                                                        autoRanging="false" tickUnit="25"
                                                        style="-fx-tick-label-fill:#64748b;-fx-font-size:11px;"/>
                                        </yAxis>
                                    </BarChart>
                                </VBox>
                            </HBox>

                            <!-- ── ROW 5: Humeur line chart (full width) ─── -->
                            <VBox styleClass="sym-card" spacing="10">
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <VBox spacing="2">
                                        <Label text="ÉVOLUTION DE L'HUMEUR — 7 JOURS"
                                               styleClass="sym-card-title card-title"/>
                                        <Label text="Score humeur quotidien en %"
                                               style="-fx-text-fill:#334155;-fx-font-size:12px;"/>
                                    </VBox>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="humeurTrendBadge" text="↓ En déclin"
                                           styleClass="sym-trend-badge sym-trend-down"/>
                                </HBox>
                                <LineChart fx:id="humeurLineChart" createSymbols="true"
                                           animated="false" legendVisible="false" prefHeight="200"
                                           style="-fx-background-color:transparent;">
                                    <xAxis><CategoryAxis
                                            style="-fx-tick-label-fill:#64748b;-fx-font-size:11px;"/></xAxis>
                                    <yAxis>
                                        <NumberAxis lowerBound="0" upperBound="100"
                                                    autoRanging="false" tickUnit="33"
                                                    style="-fx-tick-label-fill:#64748b;-fx-font-size:11px;"/>
                                    </yAxis>
                                </LineChart>
                            </VBox>

                            <!-- ── ROW 6: Trends + Highlights ────────────── -->
                            <HBox spacing="16">

                                <!-- Trends card -->
                                <VBox styleClass="sym-card" spacing="14" HBox.hgrow="ALWAYS">
                                    <Label text="TENDANCES OBSERVÉES"
                                           styleClass="sym-card-title card-title"/>
                                    <VBox spacing="8">
                                        <HBox spacing="10" alignment="CENTER_LEFT"
                                              styleClass="sym-trend-row">
                                            <Label text="Humeur" styleClass="sym-trend-label"/>
                                            <Region HBox.hgrow="ALWAYS"/>
                                            <Label fx:id="humeurTrendBadgeAlt" text="↓ En déclin"
                                                   styleClass="sym-trend-badge sym-trend-down"/>
                                        </HBox>
                                    </VBox>
                                </VBox>

                                <!-- Highlights card -->
                                <VBox styleClass="sym-card" spacing="14" HBox.hgrow="ALWAYS">
                                    <Label text="POINTS FORTS &amp; À AMÉLIORER"
                                           styleClass="sym-card-title card-title"/>
                                    <VBox spacing="10">
                                        <VBox styleClass="sym-highlight sym-highlight-green" spacing="5">
                                            <Label text="🏆 Meilleur jour"
                                                   styleClass="sym-highlight-title sym-highlight-title-green"/>
                                            <Label fx:id="bestHighlightLabel2" text="—"
                                                   wrapText="true" styleClass="sym-highlight-text"/>
                                        </VBox>
                                        <VBox styleClass="sym-highlight sym-highlight-red" spacing="5">
                                            <Label text="💪 Jour le plus difficile"
                                                   styleClass="sym-highlight-title sym-highlight-title-red"/>
                                            <Label fx:id="worstHighlightLabel2" text="—"
                                                   wrapText="true" styleClass="sym-highlight-text"/>
                                        </VBox>
                                    </VBox>
                                </VBox>
                            </HBox>

                            <!-- ── ROW 7: Bottom action banner ───────────── -->
                            <HBox spacing="14" alignment="CENTER"
                                  style="-fx-background-color:rgba(20,184,166,0.06);
                                         -fx-background-radius:14;
                                         -fx-padding:18 24;
                                         -fx-border-color:rgba(20,184,166,0.15);
                                         -fx-border-radius:14;
                                         -fx-border-width:1;">
                                <Button text="✅  Faire mon check-in aujourd'hui"
                                        onAction="#handleCheckIn"
                                        style="-fx-background-color:linear-gradient(to right,#14b8a6,#0d9488);
                                               -fx-text-fill:white;-fx-background-radius:12;
                                               -fx-padding:11 22;-fx-font-size:13px;
                                               -fx-font-weight:700;-fx-cursor:hand;
                                               -fx-border-color:transparent;"/>
                                <Button text="📄  Télécharger mon PDF"
                                        onAction="#handleExportPdf"
                                        style="-fx-background-color:transparent;
                                               -fx-text-fill:#14b8a6;
                                               -fx-border-color:rgba(20,184,166,0.4);
                                               -fx-border-radius:12;-fx-border-width:2;
                                               -fx-padding:11 22;-fx-font-size:13px;
                                               -fx-font-weight:700;-fx-cursor:hand;"/>
                            </HBox>

                        </VBox>
                    </VBox>
                </content>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
