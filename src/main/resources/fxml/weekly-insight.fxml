<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.suivi.ui.WeeklyInsightController"
            prefWidth="1200" prefHeight="720"
            styleClass="page-bg">
    <stylesheets>
        <URL value="@../css/app.css"/>
        <URL value="@../css/Weekly-insight.css"/>
    </stylesheets>

    <!-- ══ SIDEBAR ══════════════════════════════════════════════════ -->
    <left>
        <VBox styleClass="sidebar">
            <VBox styleClass="sidebar-logo-box" spacing="2">
                <Label text="bekri" styleClass="sidebar-logo"/>
                <Label text="Bien-être &amp; Objectifs" styleClass="sidebar-logo-sub"/>
            </VBox>

            <VBox styleClass="sidebar-nav-box" spacing="0">
                <Label text="MENU" styleClass="sidebar-section-label"/>
                <Button text="🏠  Accueil"             styleClass="sidebar-btn"        onAction="#handleAccueil"/>
                <Button text="🎯  Mes Objectifs"       styleClass="sidebar-btn"        onAction="#handleObjectifs"/>
                <Button text="✅  Daily Check-in"      styleClass="sidebar-btn"        onAction="#handleDailyCheckIn"/>
                <Button text="📅  Plan de la semaine"  styleClass="sidebar-btn"        onAction="#handleWeekPlan"/>
                <Button text="📈  Weekly Insights"     styleClass="sidebar-btn-active" onAction="#handleWeeklyInsights"/>
                <Button text="💬  Posts"               styleClass="sidebar-btn"        onAction="#handleCommunity"/>
                <Button text="🤖  Chatbot"             styleClass="sidebar-btn"        onAction="#handleChatBot"/>
                <Button text="🧠  Test Psychologique"  styleClass="sidebar-btn"        onAction="#handleTest"/>
                <Button text="📊  Mon Profil Psy"      styleClass="sidebar-btn"        onAction="#handleProfilPsy"/>
                <Button text="👤  Mon Profil"          styleClass="sidebar-btn"        onAction="#handleProfil"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox styleClass="sidebar-divider">
                <Button text="⎋  Déconnexion" styleClass="sidebar-logout" onAction="#handleLogout"/>
            </VBox>
        </VBox>
    </left>

    <!-- ══ MAIN CONTENT ═════════════════════════════════════════════ -->
    <center>
        <VBox>

            <!-- ── Top bar ──────────────────────────────────────────────── -->
            <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="12">
                <Label text="Insights hebdomadaires" styleClass="top-bar-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="periodLabel" text="Période" styleClass="sym-topbar-period"/>
                <Button text="📄  Télécharger PDF" onAction="#handleExportPdf"
                        styleClass="sym-export-btn"/>
            </HBox>

            <ScrollPane fx:id="rootScroll" fitToWidth="true" styleClass="sym-scroll" VBox.vgrow="ALWAYS">
                <content>
                    <VBox spacing="20" styleClass="sym-content">
                        <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>

                        <!-- ── Empty state ────────────────────────────────────────── -->
                        <VBox fx:id="emptyStateBox" visible="false" managed="false"
                              spacing="16" styleClass="sym-empty" alignment="CENTER">
                            <Label text="📊  Aucune donnée disponible" styleClass="sym-empty-title"/>
                            <Label text="Vous n'avez pas encore rempli de check-in cette semaine. Commencez dès aujourd'hui !"
                                   wrapText="true" styleClass="sym-empty-text" maxWidth="480"/>
                            <Button text="✅  Faire mon check-in" onAction="#handleCheckIn"
                                    styleClass="sym-empty-btn"/>
                        </VBox>

                        <!-- ── All data content ────────────────────────────────────── -->
                        <VBox fx:id="contentSections" spacing="20">

                            <!-- ── ROW 1: Stat cards ───────────────────────────────── -->
                            <HBox spacing="14">

                                <!-- Jours complétés -->
                                <VBox spacing="6" HBox.hgrow="ALWAYS"
                                      styleClass="sym-stat-card sym-stat-card-teal">
                                    <Label text="JOURS COMPLÉTÉS"    styleClass="sym-stat-eyebrow"/>
                                    <Label fx:id="daysFilledLabel"   text="0 / 7" styleClass="sym-stat-value-big"/>
                                    <Label text="Cette semaine"      styleClass="sym-stat-sub"/>
                                    <Label text="✓ En bonne voie"    styleClass="sym-stat-pill sym-stat-pill-teal"/>
                                </VBox>

                                <!-- Meilleur jour -->
                                <VBox spacing="6" HBox.hgrow="ALWAYS"
                                      styleClass="sym-stat-card sym-stat-card-warning">
                                    <Label text="MEILLEUR JOUR"      styleClass="sym-stat-eyebrow"/>
                                    <Label fx:id="bestDayLabel"      text="—" styleClass="sym-stat-value-big-warning"/>
                                    <Label fx:id="bestHighlightLabel" text="—" styleClass="sym-stat-sub"/>
                                    <Label text="↑ Top journée"      styleClass="sym-stat-pill sym-stat-pill-warning"/>
                                </VBox>

                                <!-- Jour difficile -->
                                <VBox spacing="6" HBox.hgrow="ALWAYS"
                                      styleClass="sym-stat-card sym-stat-card-danger">
                                    <Label text="JOUR DIFFICILE"     styleClass="sym-stat-eyebrow"/>
                                    <Label fx:id="worstDayLabel"     text="—" styleClass="sym-stat-value-big-danger"/>
                                    <Label fx:id="worstHighlightLabel" text="—" styleClass="sym-stat-sub"/>
                                    <Label text="↓ À surveiller"     styleClass="sym-stat-pill sym-stat-pill-danger"/>
                                </VBox>

                                <!-- Score global -->
                                <VBox spacing="6" HBox.hgrow="ALWAYS"
                                      styleClass="sym-stat-card sym-stat-card-accent">
                                    <Label text="SCORE MOYEN GLOBAL" styleClass="sym-stat-eyebrow"/>
                                    <Label fx:id="globalAvgLabel"    text="—" styleClass="sym-stat-value-big-accent"/>
                                    <Label text="Toutes catégories"  styleClass="sym-stat-sub"/>
                                    <Label text="⚡ En progression"  styleClass="sym-stat-pill sym-stat-pill-accent"/>
                                </VBox>

                            </HBox>

                            <!-- ── ROW 2: Encouragement strip ─────────────────────── -->
                            <HBox styleClass="sym-encourage" spacing="12" alignment="CENTER_LEFT">
                                <Label text="💪" styleClass="quick-card-icon"/>
                                <Label fx:id="encouragementLabel"
                                       text="Vous progressez doucement — chaque jour compte."
                                       styleClass="sym-encourage-title"
                                       wrapText="true" HBox.hgrow="ALWAYS"/>
                            </HBox>

                            <!-- ── ROW 3: AI Recommendations panel ────────────────── -->
                            <VBox styleClass="sym-reco-panel" spacing="16">
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label text="✨" styleClass="quick-card-icon"/>
                                    <VBox spacing="2">
                                        <Label text="Objectifs recommandés par l'IA"
                                               styleClass="sym-reco-title"/>
                                        <Label text="Basés sur vos résultats de la semaine — cliquez pour les ajouter"
                                               styleClass="sym-reco-subtitle"/>
                                    </VBox>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="aiStatusLabel"
                                           text=""
                                           styleClass="ai-status-label"/>
                                </HBox>
                                <!-- Cards injected here by controller -->
                                <HBox fx:id="recommendationBox" spacing="14"/>
                            </VBox>

                            <!-- ── ROW 4: Donut + Bar charts ───────────────────────── -->
                            <HBox spacing="16">

                                <!-- Donut -->
                                <VBox styleClass="sym-card" spacing="10" HBox.hgrow="ALWAYS">
                                    <Label text="SCORE MOYEN TOUTES CATÉGORIES"
                                           styleClass="sym-card-title"/>
                                    <StackPane styleClass="sym-donut-wrap">
                                        <PieChart fx:id="globalPieChart"
                                                  legendVisible="false" labelsVisible="false"
                                                  styleClass="sym-donut" prefHeight="210"/>
                                        <VBox alignment="CENTER" spacing="2">
                                            <Label fx:id="donutCenterLabel" text="0%"
                                                   styleClass="sym-donut-center"/>
                                            <Label text="global" styleClass="sym-stat-eyebrow"/>
                                        </VBox>
                                    </StackPane>
                                </VBox>

                                <!-- Bar chart -->
                                <VBox styleClass="sym-card" spacing="10" HBox.hgrow="ALWAYS">
                                    <Label text="SCORES PAR CATÉGORIE (0–100%)"
                                           styleClass="sym-card-title"/>
                                    <BarChart fx:id="categoryBarChart" animated="false"
                                              legendVisible="false" prefHeight="230"
                                              styleClass="sym-donut">
                                        <xAxis><CategoryAxis styleClass="sym-stat-eyebrow"/></xAxis>
                                        <yAxis>
                                            <NumberAxis lowerBound="0" upperBound="100"
                                                        autoRanging="false" tickUnit="25"
                                                        styleClass="sym-stat-eyebrow"/>
                                        </yAxis>
                                    </BarChart>
                                </VBox>

                            </HBox>

                            <!-- ── ROW 5: Humeur line chart (full width) ───────────── -->
                            <VBox styleClass="sym-card" spacing="10">
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <VBox spacing="2">
                                        <Label text="ÉVOLUTION DE L'HUMEUR — 7 JOURS"
                                               styleClass="sym-card-title"/>
                                        <Label text="Score humeur quotidien en %"
                                               styleClass="sym-stat-sub"/>
                                    </VBox>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <!-- ← fx:id wired to humeurTrendBadge in controller -->
                                    <Label fx:id="humeurTrendBadge" text="↓ En déclin"
                                           styleClass="sym-trend-badge sym-trend-down"/>
                                </HBox>
                                <LineChart fx:id="humeurLineChart" createSymbols="true"
                                           animated="false" legendVisible="false" prefHeight="200"
                                           styleClass="sym-donut">
                                    <xAxis><CategoryAxis styleClass="sym-stat-eyebrow"/></xAxis>
                                    <yAxis>
                                        <NumberAxis lowerBound="0" upperBound="100"
                                                    autoRanging="false" tickUnit="33"
                                                    styleClass="sym-stat-eyebrow"/>
                                    </yAxis>
                                </LineChart>
                            </VBox>

                            <!-- ── ROW 6: Trends + Highlights ─────────────────────── -->
                            <HBox spacing="16">

                                <!-- Trends card -->
                                <VBox styleClass="sym-card" spacing="14" HBox.hgrow="ALWAYS">
                                    <Label text="TENDANCES OBSERVÉES" styleClass="sym-card-title"/>
                                    <VBox spacing="8">
                                        <HBox spacing="10" alignment="CENTER_LEFT"
                                              styleClass="sym-trend-row">
                                            <Label text="Humeur" styleClass="sym-trend-label"/>
                                            <Region HBox.hgrow="ALWAYS"/>
                                            <!-- ← fx:id wired to humeurTrendBadgeAlt — was missing before! -->
                                            <Label fx:id="humeurTrendBadgeAlt" text="↓ En déclin"
                                                   styleClass="sym-trend-badge sym-trend-down"/>
                                        </HBox>
                                    </VBox>
                                </VBox>

                                <!-- Highlights card -->
                                <VBox styleClass="sym-card" spacing="14" HBox.hgrow="ALWAYS">
                                    <Label text="POINTS FORTS &amp; À AMÉLIORER"
                                           styleClass="sym-card-title"/>
                                    <VBox spacing="10">
                                        <VBox styleClass="sym-highlight sym-highlight-green" spacing="5">
                                            <Label text="🏆 Meilleur jour"
                                                   styleClass="sym-highlight-title sym-highlight-title-green"/>
                                            <Label fx:id="bestHighlightLabel2" text="—"
                                                   wrapText="true" styleClass="sym-highlight-text"/>
                                        </VBox>
                                        <VBox styleClass="sym-highlight sym-highlight-red" spacing="5">
                                            <Label text="💪 Jour le plus difficile"
                                                   styleClass="sym-highlight-title sym-highlight-title-red"/>
                                            <Label fx:id="worstHighlightLabel2" text="—"
                                                   wrapText="true" styleClass="sym-highlight-text"/>
                                        </VBox>
                                    </VBox>
                                </VBox>

                            </HBox>

                            <!-- ── ROW 7: Bottom action banner ────────────────────── -->
                            <HBox spacing="14" alignment="CENTER" styleClass="sym-action-banner">
                                <Button text="✅  Faire mon check-in aujourd'hui"
                                        onAction="#handleCheckIn"
                                        styleClass="sym-action-btn-primary"/>
                                <Button text="📄  Télécharger mon PDF"
                                        onAction="#handleExportPdf"
                                        styleClass="sym-action-btn-outline"/>
                            </HBox>

                        </VBox>
                    </VBox>
                </content>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
