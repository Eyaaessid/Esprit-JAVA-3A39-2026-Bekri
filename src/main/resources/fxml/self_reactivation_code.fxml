<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.user.ui.SelfReactivationCodeController"
            prefWidth="960" prefHeight="640">
    <center>
        <VBox alignment="CENTER" spacing="18" styleClass="auth-right-panel">
            <padding><Insets top="48" right="48" bottom="48" left="48"/></padding>

            <VBox styleClass="auth-form-card" spacing="14" maxWidth="560">
                <VBox spacing="4">
                    <Label text="Reactiver mon compte" styleClass="auth-title"/>
                    <Label fx:id="infoLabel" text="Un code de reactivation a ete envoye." wrapText="true" styleClass="auth-subtitle"/>
                </VBox>
                <Separator/>

                <TextField fx:id="emailField" promptText="Adresse email" styleClass="text-field"/>
                <TextField fx:id="tokenField" promptText="Entrez le code recu par email" styleClass="text-field"/>

                <Label fx:id="statusLabel" wrapText="true" managed="false" visible="false" styleClass="error-label"/>

                <HBox spacing="10">
                    <Button fx:id="verifyButton" text="Verifier" onAction="#handleVerify" styleClass="btn-primary"/>
                    <Button fx:id="resendButton" text="Renvoyer le code" onAction="#handleResend" styleClass="btn-secondary"/>
                </HBox>

                <Hyperlink fx:id="backToLoginLink" text="Retour a la connexion" onAction="#goToLogin"/>
            </VBox>
        </VBox>
    </center>
</BorderPane>
