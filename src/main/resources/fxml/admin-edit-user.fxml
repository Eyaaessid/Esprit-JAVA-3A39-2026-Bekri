<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.user.ui.AdminUserEditController"
            prefWidth="700" prefHeight="460" styleClass="page-bg">
    <stylesheets>
        <URL value="@/css/admin-edit.css"/>
    </stylesheets>
    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="12">
            <Button text="Retour" styleClass="btn-ghost" onAction="#handleCancel"/>
            <Label text="Modifier role et statut" styleClass="top-bar-title"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="20" maxWidth="460" alignment="TOP_CENTER"
              style="-fx-padding: 32; -fx-background-color: white;">
            <Label fx:id="titleLabel" text="Utilisateur" styleClass="section-title"/>

            <Label text="Role" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-font-size: 13px;"/>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Region fx:id="roleIndicator"
                        style="-fx-background-color: #27ae60; -fx-background-radius: 5;
                               -fx-min-width: 10; -fx-min-height: 10;
                               -fx-max-width: 10; -fx-max-height: 10;"/>
                <ComboBox fx:id="roleComboBox" prefWidth="340" maxWidth="340"/>
            </HBox>

            <Label text="Statut" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-font-size: 13px;"/>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Region fx:id="statutIndicator"
                        style="-fx-background-color: #27ae60; -fx-background-radius: 5;
                               -fx-min-width: 10; -fx-min-height: 10;
                               -fx-max-width: 10; -fx-max-height: 10;"/>
                <ComboBox fx:id="statutComboBox" prefWidth="340" maxWidth="340"/>
            </HBox>

            <Label fx:id="statusLabel" managed="false" visible="false"/>

            <HBox spacing="10">
                <Button fx:id="saveButton" text="Enregistrer" onAction="#handleSave"/>
                <Button fx:id="cancelButton" text="Annuler" onAction="#handleCancel"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
