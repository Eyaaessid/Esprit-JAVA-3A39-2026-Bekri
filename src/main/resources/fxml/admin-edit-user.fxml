<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.user.ui.AdminUserEditController"
            prefWidth="720" prefHeight="520"
            styleClass="page-bg admin-edit-page">
    <stylesheets>
        <URL value="@../css/bekri.css"/>
        <URL value="@/css/admin-edit.css"/>
    </stylesheets>

    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="12">
            <Button text="Retour" styleClass="btn-ghost" onAction="#handleCancel"/>
            <Label text="Modifier utilisateur" styleClass="top-bar-title"/>
        </HBox>
    </top>

    <center>
        <StackPane style="-fx-padding: 28;">
            <VBox maxWidth="560" spacing="18" styleClass="admin-edit-card">
                <HBox alignment="CENTER_LEFT" spacing="16" styleClass="admin-edit-hero">
                    <StackPane styleClass="admin-edit-avatar-wrap">
                        <Label fx:id="avatarLabel" text="U" styleClass="admin-edit-avatar"/>
                    </StackPane>

                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label fx:id="titleLabel" text="Utilisateur" styleClass="admin-edit-title"/>
                        <Label fx:id="subtitleLabel" text="email@bekri.com" styleClass="admin-edit-subtitle"/>
                        <HBox spacing="8">
                            <Label fx:id="currentRoleBadge" text="Utilisateur"/>
                            <Label fx:id="currentStatusBadge" text="Actif"/>
                        </HBox>
                    </VBox>
                </HBox>

                <VBox spacing="14" styleClass="admin-edit-section">
                    <Label text="Permissions du compte" styleClass="admin-edit-section-title"/>
                    <Label text="Choisissez le role et le statut visibles dans l'application." styleClass="admin-edit-help"/>

                    <VBox spacing="10">
                        <Label text="Role" styleClass="admin-edit-field-label"/>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Region fx:id="roleIndicator"
                                    style="-fx-background-color: #217693; -fx-background-radius: 5;
                                           -fx-min-width: 10; -fx-min-height: 10;
                                           -fx-max-width: 10; -fx-max-height: 10;"/>
                            <ComboBox fx:id="roleComboBox" prefWidth="360" maxWidth="360"/>
                        </HBox>
                    </VBox>

                    <VBox spacing="10">
                        <Label text="Statut" styleClass="admin-edit-field-label"/>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Region fx:id="statutIndicator"
                                    style="-fx-background-color: #217693; -fx-background-radius: 5;
                                           -fx-min-width: 10; -fx-min-height: 10;
                                           -fx-max-width: 10; -fx-max-height: 10;"/>
                            <ComboBox fx:id="statutComboBox" prefWidth="360" maxWidth="360"/>
                        </HBox>
                    </VBox>
                </VBox>

                <Label fx:id="statusLabel" managed="false" visible="false" styleClass="admin-edit-feedback"/>

                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Button fx:id="cancelButton" text="Annuler" onAction="#handleCancel"/>
                    <Button fx:id="saveButton" text="Enregistrer" onAction="#handleSave"/>
                </HBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
