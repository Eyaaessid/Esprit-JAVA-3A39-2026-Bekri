<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.user.ui.TwoFactorDisableController"
            prefWidth="680" prefHeight="420">
    <center>
        <VBox spacing="14" maxWidth="500" styleClass="card">
            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
            <Label fx:id="titleLabel" text="Désactivation de l'authentification à deux facteurs" styleClass="section-title"/>
            <Label fx:id="warningLabel" text="Cette action supprimera la protection 2FA de votre compte."
                   wrapText="true" style="-fx-text-fill: #b42318; -fx-font-weight: bold;"/>
            <Separator/>
            <Label text="Mot de passe actuel"/>
            <PasswordField fx:id="currentPasswordField" promptText="••••••••"/>
            <Label fx:id="statusLabel"/>
            <HBox spacing="10">
                <Button fx:id="actionButton" text="Désactiver 2FA" styleClass="btn-danger" onAction="#handleConfirm"/>
                <Button text="Annuler" styleClass="btn-secondary" onAction="#handleCancel"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
