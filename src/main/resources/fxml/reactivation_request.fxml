<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.user.ui.ReactivationRequestController"
            prefWidth="820" prefHeight="600">
    <center>
        <StackPane>
            <VBox spacing="18" maxWidth="520" styleClass="auth-form-card">
                <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                <Label text="Demande de reactivation" styleClass="auth-title"/>
                <Label text="Envoyez une demande a l'administrateur si votre compte a ete desactive."
                       wrapText="true" styleClass="auth-subtitle"/>

                <VBox spacing="8">
                    <Label text="Adresse email" styleClass="input-label"/>
                    <TextField fx:id="emailField" promptText="vous@exemple.com"/>
                </VBox>

                <VBox spacing="8">
                    <Label text="Motif de la demande" styleClass="input-label"/>
                    <TextArea fx:id="reasonArea" wrapText="true" prefRowCount="7"
                              promptText="Expliquez pourquoi vous souhaitez reactiver votre compte..."/>
                    <Label fx:id="charCountLabel" text="0 caracteres" styleClass="muted"/>
                </VBox>

                <Label fx:id="statusLabel" text="" wrapText="true"/>

                <HBox spacing="10">
                    <Button fx:id="submitButton" text="Envoyer" onAction="#handleSubmit" styleClass="btn-primary"/>
                    <Button fx:id="returnButton" text="Retour"
                            onAction="#handleBackToLogin" styleClass="btn-ghost"
                            visible="true" managed="true"/>
                </HBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
