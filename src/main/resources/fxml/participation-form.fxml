<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.evenement.ui.ParticipationFormController"
      spacing="16" prefWidth="420" styleClass="section-card">
    <stylesheets><URL value="@../css/app.css"/></stylesheets>
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
    <Label text="Participation" styleClass="page-title" style="-fx-font-size: 20px;"/>
    <VBox spacing="6">
        <Label text="Statut" styleClass="input-label"/>
        <ComboBox fx:id="cmbStatut" styleClass="combo-box" maxWidth="Infinity"/>
    </VBox>
    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button text="Annuler" styleClass="btn-secondary" onAction="#handleAnnuler"/>
        <Button text="Enregistrer" styleClass="btn-primary" onAction="#handleEnregistrer"/>
    </HBox>
</VBox>
