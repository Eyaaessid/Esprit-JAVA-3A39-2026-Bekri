<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.user.ui.AdminAddUserController"
      styleClass="dashboard-root"
      prefWidth="900" prefHeight="700">

    <HBox styleClass="topnav" alignment="CENTER_LEFT" spacing="12">
        <padding><Insets top="14" right="28" bottom="14" left="28"/></padding>
        <Label text="Bekri" styleClass="nav-brand"/>
        <Label text="Ajouter un utilisateur" styleClass="nav-section" HBox.hgrow="ALWAYS"/>
        <Hyperlink text="← Retour à la liste" styleClass="nav-link" onAction="#goBack"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="form-scroll">
        <VBox styleClass="dashboard-content">
            <padding><Insets top="24" right="24" bottom="40" left="24"/></padding>

            <Label text="Ajouter un utilisateur" styleClass="dashboard-title"/>
            <Label text="Créer un nouveau compte depuis l'administration" styleClass="dashboard-sub"/>

            <Label fx:id="generalFormErrorLabel" styleClass="error-banner" wrapText="true"
                   managed="false" visible="false"/>

            <Label fx:id="errorLabel" styleClass="error-banner" wrapText="true"
                   managed="false" visible="false"/>
            <Label fx:id="successLabel" styleClass="success-label" wrapText="true"
                   managed="false" visible="false"/>

            <VBox styleClass="profil-card" spacing="16">
                <VBox.margin><Insets top="24"/></VBox.margin>
                <Label text="👤  Informations du nouvel utilisateur" styleClass="card-title"/>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <Label text="Nom" styleClass="form-field-label"/>
                            <Label text="*" styleClass="required-star"/>
                        </HBox>
                        <TextField fx:id="nomField" styleClass="auth-field" promptText="Nom"
                                   style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 11 14 11 14; -fx-font-size: 13px; -fx-pref-height: 44px;"/>
                        <Label fx:id="nomErrorLabel" styleClass="error-label" wrapText="true" managed="false" visible="false"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <Label text="Prénom" styleClass="form-field-label"/>
                            <Label text="*" styleClass="required-star"/>
                        </HBox>
                        <TextField fx:id="prenomField" styleClass="auth-field" promptText="Prénom"
                                   style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 11 14 11 14; -fx-font-size: 13px; -fx-pref-height: 44px;"/>
                        <Label fx:id="prenomErrorLabel" styleClass="error-label" wrapText="true" managed="false" visible="false"/>
                    </VBox>
                </HBox>

                <VBox spacing="6">
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Label text="Email" styleClass="form-field-label"/>
                        <Label text="*" styleClass="required-star"/>
                    </HBox>
                    <TextField fx:id="emailField" styleClass="auth-field" promptText="email@exemple.com"
                               style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 11 14 11 14; -fx-font-size: 13px; -fx-pref-height: 44px;"/>
                    <Label fx:id="emailErrorLabel" styleClass="error-label" wrapText="true" managed="false" visible="false"/>
                </VBox>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Téléphone (optionnel)" styleClass="form-field-label"/>
                        <TextField fx:id="telField" styleClass="auth-field" promptText="+216 XX XXX XXX"
                                   style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 11 14 11 14; -fx-font-size: 13px; -fx-pref-height: 44px;"/>
                        <Label fx:id="telErrorLabel" styleClass="error-label" wrapText="true" managed="false" visible="false"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <Label text="Date de naissance" styleClass="form-field-label"/>
                            <Label text="*" styleClass="required-star"/>
                        </HBox>
                        <DatePicker fx:id="dateNaissancePicker" maxWidth="Infinity" styleClass="auth-field"
                                    style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 11 14 11 14; -fx-font-size: 13px; -fx-pref-height: 44px;"/>
                        <Label fx:id="dateErrorLabel" styleClass="error-label" wrapText="true" managed="false" visible="false"/>
                    </VBox>
                </HBox>

                <Separator styleClass="section-separator">
                    <VBox.margin><Insets top="8" bottom="12"/></VBox.margin>
                </Separator>

                <HBox spacing="6" alignment="CENTER_LEFT">
                    <Label text="Mot de passe" styleClass="form-field-label"/>
                    <Label text="*" styleClass="required-star"/>
                </HBox>
                <StackPane styleClass="password-field-stack password-with-toggle" maxWidth="Infinity">
                    <PasswordField fx:id="passwordField" styleClass="password-field-in-stack" maxWidth="Infinity"
                                   promptText="••••••••" style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 11 46 11 14; -fx-font-size: 13px; -fx-pref-height: 44px;"/>
                    <TextField fx:id="passwordPlainField" styleClass="password-field-in-stack" maxWidth="Infinity"
                               visible="false" managed="false"
                               style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 11 14 11 14; -fx-font-size: 13px; -fx-pref-height: 44px;"/>
                    <HBox alignment="CENTER_RIGHT" pickOnBounds="false" maxWidth="Infinity" maxHeight="Infinity">
                        <padding><Insets right="4"/></padding>
                        <Button fx:id="passwordToggleBtn" text="👁" styleClass="eye-button password-toggle-btn password-eye-integrated"/>
                    </HBox>
                </StackPane>
                <Label text="Min. 8 caractères, majuscule, minuscule, chiffre, caractère spécial (@$!%*?&amp;-_)" styleClass="field-hint"/>
                <Label fx:id="passwordErrorLabel" styleClass="error-label" wrapText="true" managed="false" visible="false"/>

                <HBox spacing="6" alignment="CENTER_LEFT">
                    <Label text="Confirmer le mot de passe" styleClass="form-field-label"/>
                    <Label text="*" styleClass="required-star"/>
                </HBox>
                <StackPane styleClass="password-field-stack password-with-toggle" maxWidth="Infinity">
                    <PasswordField fx:id="confirmPasswordField" styleClass="password-field-in-stack" maxWidth="Infinity" style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 11 46 11 14; -fx-font-size: 13px; -fx-pref-height: 44px;"/>
                    <TextField fx:id="confirmPasswordPlainField" styleClass="password-field-in-stack" maxWidth="Infinity"
                               visible="false" managed="false"
                               style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 11 14 11 14; -fx-font-size: 13px; -fx-pref-height: 44px;"/>
                    <HBox alignment="CENTER_RIGHT" pickOnBounds="false" maxWidth="Infinity" maxHeight="Infinity">
                        <padding><Insets right="4"/></padding>
                        <Button fx:id="confirmPasswordToggleBtn" text="👁" styleClass="eye-button password-toggle-btn password-eye-integrated"/>
                    </HBox>
                </StackPane>
                <Label fx:id="confirmPasswordErrorLabel" styleClass="error-label" wrapText="true" managed="false" visible="false"/>

                <VBox spacing="6">
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Label text="Rôle" styleClass="form-field-label"/>
                        <Label text="*" styleClass="required-star"/>
                    </HBox>
                    <ComboBox fx:id="roleCombo" maxWidth="Infinity" styleClass="auth-field"
                              style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 11 14 11 14; -fx-font-size: 13px; -fx-pref-height: 44px;"/>
                    <Label fx:id="roleErrorLabel" styleClass="error-label" wrapText="true" managed="false" visible="false"/>
                </VBox>
            </VBox>

            <HBox spacing="12" alignment="CENTER_RIGHT">
                <VBox.margin><Insets top="16"/></VBox.margin>
                <Button text="Annuler" styleClass="btn-secondary form-action-btn" onAction="#goBack"
                        style="-fx-background-color: #c8d0da, #ffffff; -fx-background-insets: 0, 1.5; -fx-background-radius: 10, 8.5; -fx-border-color: transparent; -fx-border-width: 0; -fx-text-fill: #2d3748; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 22 10 22; -fx-min-height: 42; -fx-pref-height: 42; -fx-cursor: hand;"/>
                <Button fx:id="saveBtn" text="+ Créer l'utilisateur"
                        styleClass="btn-primary form-submit-btn" onAction="#handleSave"
                        style="-fx-background-color: #009688; -fx-background-insets: 0; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: transparent; -fx-border-width: 0; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 12 28 12 28; -fx-min-height: 44; -fx-pref-height: 44; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </ScrollPane>
</VBox>
