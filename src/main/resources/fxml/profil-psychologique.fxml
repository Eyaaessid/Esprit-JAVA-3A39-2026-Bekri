<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>

<ScrollPane fitToWidth="true"
    fitToHeight="false"
    maxHeight="700"
    prefHeight="700"
    style="-fx-background-color: #f9fafb;"
    stylesheets="@../css/profil-psychologique.css"
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="tn.esprit.profil.ui.ProfilPsychologiqueController">
  <content>
    <VBox spacing="0" maxWidth="Infinity" style="-fx-background-color: #f9fafb; -fx-padding: 0;">

      <VBox fx:id="emptyBox" visible="false" managed="false"
            alignment="CENTER" spacing="18"
            style="-fx-padding: 80px;">
        <Label text="🧘" style="-fx-font-size: 52px;"/>
        <Label text="Aucune évaluation trouvée"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #6b7280;"/>
        <Button fx:id="passerTestBtn" text="Passer le test →"
                onAction="#handlePasserTest"
                style="-fx-background-color: #f97316; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 10px;
                       -fx-padding: 10px 28px; -fx-cursor: hand;"/>
      </VBox>

      <VBox fx:id="resultBox" visible="false" managed="false" spacing="0">

        <HBox style="-fx-padding: 16px 20px 0px 20px;">
          <Button fx:id="backBtn" text="← Retour"
                  onAction="#handleBack"
                  style="-fx-background-color: transparent;
                         -fx-text-fill: #6b7280;
                         -fx-font-size: 13px;
                         -fx-font-weight: bold;
                         -fx-cursor: hand;
                         -fx-border-color: #e5e7eb;
                         -fx-border-radius: 8px;
                         -fx-background-radius: 8px;
                         -fx-padding: 6px 14px;"/>
        </HBox>

        <VBox fx:id="headerCard" alignment="CENTER" spacing="10"
              style="-fx-padding: 40px 30px 30px 30px;">
          <Pane fx:id="arcPane" prefWidth="120" prefHeight="120"
                maxWidth="120" maxHeight="120"/>
          <Label fx:id="scoreLabel" styleClass="score-big"/>
          <Label fx:id="badgeLabel" styleClass="badge-pill"/>
          <Label fx:id="profilTypeLabel" styleClass="profil-subtitle"/>
        </VBox>

        <VBox spacing="14" style="-fx-padding: 24px 28px 0px 28px;">
          <Label text="📋  Analyse personnalisée"
                 style="-fx-font-size: 16px; -fx-font-weight: bold;
                        -fx-text-fill: #1f2937;"/>

          <VBox fx:id="card1" spacing="8"
                styleClass="analysis-card"
                style="-fx-border-color: #f97316; -fx-border-width: 0 0 0 4px;
                       -fx-background-color: #fff7ed;">
            <HBox spacing="8" alignment="CENTER_LEFT">
              <Label text="🧠" style="-fx-font-size: 18px;"/>
              <Label text="Résumé émotionnel"
                     styleClass="card-title"
                     style="-fx-text-fill: #f97316;"/>
            </HBox>
            <Label fx:id="feedbackPart1" styleClass="card-body"
                   wrapText="true"/>
          </VBox>

          <VBox fx:id="card2" spacing="8"
                styleClass="analysis-card"
                style="-fx-border-color: #3b82f6; -fx-border-width: 0 0 0 4px;
                       -fx-background-color: #eff6ff;">
            <HBox spacing="8" alignment="CENTER_LEFT">
              <Label text="🔍" style="-fx-font-size: 18px;"/>
              <Label text="Interprétation"
                     styleClass="card-title"
                     style="-fx-text-fill: #3b82f6;"/>
            </HBox>
            <Label fx:id="feedbackPart2" styleClass="card-body"
                   wrapText="true"/>
          </VBox>

          <VBox fx:id="card3" spacing="8"
                styleClass="analysis-card"
                style="-fx-border-color: #10b981; -fx-border-width: 0 0 0 4px;
                       -fx-background-color: #f0fdf4;">
            <HBox spacing="8" alignment="CENTER_LEFT">
              <Label text="🌿" style="-fx-font-size: 18px;"/>
              <Label text="Conseils de posture mentale"
                     styleClass="card-title"
                     style="-fx-text-fill: #10b981;"/>
            </HBox>
            <Label fx:id="feedbackPart3" styleClass="card-body"
                   wrapText="true"/>
          </VBox>

          <Label fx:id="feedbackLabel" visible="false" managed="false"/>
        </VBox>

        <HBox alignment="CENTER" style="-fx-padding: 20px 0 0 0;">
          <Button fx:id="repasserBtn" text="Régénérer l'analyse ✨"
                  styleClass="regen-btn"
                  onAction="#handleRegenerateInsight"/>
        </HBox>

        <VBox style="-fx-padding: 28px 28px 0 28px;" spacing="12">
          <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="●" style="-fx-text-fill: #10b981; -fx-font-size: 18px;"/>
            <Label text="Objectifs bien-être recommandés"
                   styleClass="section-header"/>
          </HBox>
          <VBox fx:id="recommendationsBox" spacing="10"/>
        </VBox>

        <VBox style="-fx-padding: 28px 28px 40px 28px;" spacing="8"
              alignment="CENTER">
          <Separator/>
          <Label fx:id="dateLabel" styleClass="date-label"/>
        </VBox>

        <Button fx:id="regenerateInsightBtn" visible="false" managed="false"
                onAction="#handleRegenerateInsight"/>

      </VBox>
    </VBox>
  </content>
</ScrollPane>
