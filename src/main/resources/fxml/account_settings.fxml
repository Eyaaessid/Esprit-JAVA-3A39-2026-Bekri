<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.user.ui.AccountSettingsController"
            prefWidth="900" prefHeight="620" styleClass="page-bg">
    <top>
        <HBox spacing="12" alignment="CENTER_LEFT" styleClass="top-bar">
            <Button text="Retour" onAction="#handleBack" styleClass="btn-ghost"/>
            <Label text="Paramètres du compte" styleClass="top-bar-title"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="18" maxWidth="720" style="-fx-padding: 28;">
            <VBox spacing="12" styleClass="card">
                <Label text="Statut du compte" styleClass="section-title"/>
                <Label fx:id="statusBadgeLabel" text="-" />
                <Label fx:id="messageLabel" text="" wrapText="true"/>

                <Button fx:id="deactivateButton" text="Désactiver mon compte"
                        onAction="#handleDeactivate" styleClass="btn-danger"
                        visible="false" managed="false"/>

                <Button fx:id="showRequestButton" text="Demander une réactivation"
                        onAction="#handleShowRequestForm" styleClass="btn-primary"
                        visible="false" managed="false"/>

                <TextArea fx:id="reasonArea" promptText="Expliquez brièvement votre demande..."
                          wrapText="true" prefRowCount="6" visible="false" managed="false"/>

                <Button fx:id="submitRequestButton" text="Envoyer la demande"
                        onAction="#handleSubmitRequest" styleClass="btn-primary"
                        visible="false" managed="false"/>

                <Label fx:id="feedbackLabel" text="" wrapText="true"/>
            </VBox>
        </VBox>
    </center>
</BorderPane>
