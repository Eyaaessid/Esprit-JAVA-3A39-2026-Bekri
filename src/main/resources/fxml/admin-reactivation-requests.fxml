<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.user.ui.AdminReactivationRequestsController"
            prefWidth="1100" prefHeight="700" styleClass="page-bg">
    <stylesheets>
        <URL value="@../css/bekri.css"/>
    </stylesheets>

    <left>
        <VBox styleClass="sidebar">
            <VBox styleClass="sidebar-logo-box" spacing="2">
                <Label text="bekri" styleClass="sidebar-logo"/>
                <Label text="Bien-etre &amp; Administration" styleClass="sidebar-logo-sub"/>
            </VBox>
            <VBox styleClass="sidebar-nav-box" spacing="0">
                <Label text="MENU" styleClass="sidebar-section-label"/>
                <Button text="Accueil"          styleClass="sidebar-btn" onAction="#handleAccueil"/>
                <Button text="Questions"         styleClass="sidebar-btn" onAction="#handleQuestions"/>
                <Button text="Utilisateurs"      styleClass="sidebar-btn" onAction="#handleUtilisateurs"/>
                <Button text="Reactivations"     styleClass="sidebar-btn sidebar-btn-active"/>
                <Button text="Mon Profil"        styleClass="sidebar-btn" onAction="#handleProfil"/>
            </VBox>
            <Region VBox.vgrow="ALWAYS"/>
            <VBox styleClass="sidebar-divider">
                <Button text="Deconnexion" styleClass="sidebar-logout" onAction="#handleLogout"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="0">
            <!-- Top bar -->
            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="top-bar">
                <Button text="Retour" onAction="#handleAccueil" styleClass="btn-ghost"/>
                <Label text="Demandes de reactivation" styleClass="top-bar-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Actualiser" onAction="#handleRefresh" styleClass="btn-secondary"/>
            </HBox>

            <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
                <VBox spacing="24">
                    <padding><Insets top="32" right="36" bottom="32" left="36"/></padding>

                    <!-- Summary banner -->
                    <HBox styleClass="welcome-card" alignment="CENTER_LEFT" spacing="16">
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <Label text="Demandes de reactivation en attente" styleClass="welcome-greeting"/>
                            <Label fx:id="pendingCountLabel" text="Chargement..." styleClass="welcome-tagline"/>
                        </VBox>
                    </HBox>

                    <!-- List -->
                    <VBox spacing="12">
                        <Label text="Comptes inactifs (desactives par admin)" styleClass="section-title"/>

                        <!-- Empty state -->
                        <Label fx:id="emptyLabel"
                               text="Aucune demande de reactivation en attente."
                               styleClass="empty-state-label"
                               wrapText="true"
                               visible="false" managed="false"/>

                        <!-- Requests list -->
                        <ListView fx:id="requestsListView"
                                  styleClass="users-list"
                                  VBox.vgrow="ALWAYS"
                                  minHeight="300"/>
                    </VBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>