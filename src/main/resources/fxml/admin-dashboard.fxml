<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.user.ui.AdminDashboardController"
            prefWidth="1100" prefHeight="700" styleClass="page-bg">

    <left>
        <VBox styleClass="sidebar">
            <VBox styleClass="sidebar-logo-box" spacing="2">
                <Label text="bekri" styleClass="sidebar-logo"/>
                <Label text="Bien-être &amp; Administration" styleClass="sidebar-logo-sub"/>
            </VBox>
            <VBox styleClass="sidebar-nav-box" spacing="0">
                <Label text="MENU" styleClass="sidebar-section-label"/>
                <Button text="🏠  Accueil" styleClass="sidebar-btn sidebar-btn-active"/>
                <Button text="❓  Questions" styleClass="sidebar-btn" onAction="#handleQuestions"/>
                <Button text="👥  Utilisateurs" styleClass="sidebar-btn" onAction="#handleUtilisateurs"/>
                <Button text="📨  Réactivations" styleClass="sidebar-btn" onAction="#handleReactivationRequests"/>
                <Button text="👤  Mon Profil" styleClass="sidebar-btn" onAction="#handleProfil"/>
            </VBox>
            <Region VBox.vgrow="ALWAYS"/>
            <VBox styleClass="sidebar-divider">
                <Button text="⎋  Déconnexion" styleClass="sidebar-logout" onAction="#handleLogout"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox spacing="24">
                <padding><Insets top="32" right="36" bottom="32" left="36"/></padding>

                <HBox styleClass="welcome-card" alignment="CENTER_LEFT" spacing="16">
                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <Label fx:id="welcomeLabel" text="Bonjour Admin 👋" styleClass="welcome-greeting"/>
                        <Label text="Gérez votre plateforme bien-être" styleClass="welcome-tagline"/>
                    </VBox>
                    <Label text="💙" style="-fx-font-size: 48px; -fx-text-fill: #FFFFFF; -fx-opacity: 0.6;"/>
                </HBox>

                <VBox spacing="16">
                    <Label text="Accès rapide" styleClass="section-title"/>
                    <FlowPane hgap="16" vgap="16">
                        <VBox styleClass="quick-card" onMouseClicked="#handleQuestions" alignment="CENTER" spacing="8">
                            <Label text="❓" styleClass="quick-card-icon"/>
                            <Label text="Questions" styleClass="quick-card-title"/>
                            <Label text="Gérer les questions" styleClass="quick-card-sub"/>
                        </VBox>
                        <VBox styleClass="quick-card" onMouseClicked="#handleUtilisateurs" alignment="CENTER" spacing="8">
                            <Label text="👥" styleClass="quick-card-icon"/>
                            <Label text="Utilisateurs" styleClass="quick-card-title"/>
                            <Label text="Gérer les comptes" styleClass="quick-card-sub"/>
                        </VBox>
                        <VBox styleClass="quick-card" onMouseClicked="#handleReactivationRequests" alignment="CENTER" spacing="8">
                            <Label text="📨" styleClass="quick-card-icon"/>
                            <Label text="Réactivations" styleClass="quick-card-title"/>
                            <Label text="Traiter les demandes" styleClass="quick-card-sub"/>
                        </VBox>
                        <VBox styleClass="quick-card" onMouseClicked="#handleProfil" alignment="CENTER" spacing="8">
                            <Label text="👤" styleClass="quick-card-icon"/>
                            <Label text="Mon Profil" styleClass="quick-card-title"/>
                            <Label text="Mes informations" styleClass="quick-card-sub"/>
                        </VBox>
                    </FlowPane>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
