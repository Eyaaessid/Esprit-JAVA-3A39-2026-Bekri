<?xml version="1.0" encoding="UTF-8"?>
<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.community.ui.PostsController"
            styleClass="page-bg"
            prefWidth="1100"
            prefHeight="700">
    <stylesheets>
        <String fx:value="/css/bekri.css"/>
        <String fx:value="/css/community-posts.css"/>
    </stylesheets>

    <left>
        <VBox styleClass="sidebar">
            <VBox styleClass="sidebar-logo-box" spacing="2">
                <Label text="bekri" styleClass="sidebar-logo"/>
                <Label text="Bien-être &amp; Objectifs" styleClass="sidebar-logo-sub"/>
            </VBox>

            <VBox styleClass="sidebar-nav-box" spacing="0">
                <Label text="MENU" styleClass="sidebar-section-label"/>
                <Button text="🏠  Accueil" styleClass="sidebar-btn" onAction="#handleAccueil"/>
                <Button text="🎯  Mes Objectifs" styleClass="sidebar-btn" onAction="#handleObjectifs"/>
                <Button text="✅  Daily Check-in" styleClass="sidebar-btn" onAction="#handleDailyCheckIn"/>
                <Button text="📅  Plan de la semaine" styleClass="sidebar-btn" onAction="#handleWeekPlan"/>
                <Button text="📈  Weekly Insights" styleClass="sidebar-btn" onAction="#handleWeeklyInsights"/>
                <Button text="💬  Posts" styleClass="sidebar-btn sidebar-btn-active" onAction="#handleCommunity"/>
                <Button text="🤖  Chatbot" styleClass="sidebar-btn" onAction="#handleChatBot"/>
                <Button text="🧠  Test Psychologique" styleClass="sidebar-btn" onAction="#handleTest"/>
                <Button text="📊  Mon Profil Psy" styleClass="sidebar-btn" onAction="#handleProfilPsy"/>
                <Button text="👤  Mon Profil" styleClass="sidebar-btn" onAction="#handleProfil"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox styleClass="sidebar-divider">
                <Button text="⎋  Déconnexion" styleClass="sidebar-logout" onAction="#handleLogout"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox>
            <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="2">
                    <Label text="Community Posts" styleClass="top-bar-title"/>
                    <Label text="Support, partage et entraide dans le même style que le reste de l'app" styleClass="muted"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="savedFilterButton" text="Saved Posts" styleClass="btn-ghost posts-top-button" onAction="#handleToggleSavedFilter"/>
                <Button text="+ Nouveau post" styleClass="btn-primary posts-top-button" onAction="#handleCreatePost"/>
                <StackPane>
                    <Button fx:id="notificationsButton" text="Notifications" styleClass="btn-secondary notification-button posts-top-button" onAction="#handleOpenNotifications"/>
                    <Label fx:id="notificationBadgeLabel" text="0" styleClass="notification-badge" visible="false" managed="false"/>
                </StackPane>
                <Button text="Refresh" styleClass="btn-secondary posts-top-button" onAction="#handleRefresh"/>
            </HBox>

            <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
                <VBox spacing="20" styleClass="posts-page-shell">
                    <padding>
                        <Insets top="28" right="36" bottom="28" left="36"/>
                    </padding>

                    <VBox spacing="16" styleClass="welcome-card posts-hero-card">
                        <Label text="Espace posts" styleClass="welcome-greeting"/>
                        <Label text="Une mise en page cohérente avec Bekri, des cartes plus douces, une palette calme et une lecture plus claire." styleClass="welcome-tagline" wrapText="true"/>
                    </VBox>

                    <VBox spacing="16" styleClass="card posts-main-card">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Fil d'actualité" styleClass="section-title"/>
                                <Label fx:id="feedInfoLabel" text="0 post(s) loaded" styleClass="muted"/>
                            </VBox>
                            <VBox spacing="6" visible="false" managed="false">
                                <Label text="Utilisateur actif" styleClass="section-label"/>
                                <ComboBox fx:id="currentUserComboBox" prefWidth="220"/>
                            </VBox>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="posts-filter-strip">
                            <TextField fx:id="searchField" promptText="Rechercher par titre, contenu ou catégorie..." styleClass="text-field posts-search-field" onAction="#handleSearch" HBox.hgrow="ALWAYS"/>
                            <ComboBox fx:id="categoryComboBox" promptText="Toutes les catégories" styleClass="combo-box posts-category-combo" prefWidth="180" onAction="#handleSearch"/>
                            <Button text="Rechercher" styleClass="btn-primary" onAction="#handleSearch"/>
                            <Button text="Réinitialiser" styleClass="btn-ghost" onAction="#handleResetFilters"/>
                        </HBox>

                        <VBox fx:id="postsContainer" spacing="16" styleClass="posts-container"/>

                        <HBox fx:id="paginationBar" alignment="CENTER" spacing="8">
                            <Button fx:id="btnPrev" text="← Précédent" styleClass="btn-ghost" onAction="#handlePrev"/>
                            <Label fx:id="pageLabel" text="Page 1 / 1" styleClass="muted"/>
                            <Button fx:id="btnNext" text="Suivant →" styleClass="btn-ghost" onAction="#handleNext"/>
                        </HBox>
                    </VBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
