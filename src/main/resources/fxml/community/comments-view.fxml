<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.community.ui.CommentsController">
    <stylesheets>
        <String fx:value="/css/community.css" />
    </stylesheets>
    <top>
        <VBox spacing="0.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="0.0" right="0.0" bottom="0.0" left="0.0"/>
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="18.0" styleClass="topbar-shell">
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Label styleClass="brand-title" text="Bekri"/>
                </HBox>
                <VBox alignment="CENTER_LEFT" spacing="2.0">
                    <Label styleClass="screen-title" text="Comments"/>
                    <Label styleClass="screen-subtitle" text="Discussion space"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button onAction="#handleBackToDashboard" styleClass="topbar-button" text="Dashboard"/>
                <Button onAction="#handleBackToPosts" styleClass="topbar-button" text="Back To Posts"/>
                <Button onAction="#handleBackToDetails" styleClass="topbar-button" text="Back To Details"/>
                <Button onAction="#handleAddComment" styleClass="primary-button" text="Add Comment"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="16.0">
            <padding>
                <Insets top="16.0" right="24.0" bottom="24.0" left="24.0"/>
            </padding>
            <HBox spacing="12.0">
                <VBox spacing="6.0">
                    <Label styleClass="section-label" text="Logged-in User"/>
                    <ComboBox fx:id="currentUserComboBox" prefWidth="260.0"/>
                </VBox>
            </HBox>
            <VBox spacing="6.0" styleClass="detail-card">
                <padding>
                    <Insets top="16.0" right="16.0" bottom="16.0" left="16.0"/>
                </padding>
                <Label fx:id="postTitleLabel" styleClass="detail-title" text="Post title"/>
                <Label fx:id="postSummaryLabel" styleClass="muted-label" text="Post summary"/>
                <Label fx:id="commentsCountLabel" styleClass="section-label" text="0 comment(s)"/>
            </VBox>
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS">
                <content>
                    <VBox fx:id="commentsContainer" spacing="12.0"/>
                </content>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
