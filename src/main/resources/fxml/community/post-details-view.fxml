<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.community.ui.PostDetailsController">
    <stylesheets>
        <String fx:value="/css/community.css" />
    </stylesheets>
    <top>
        <VBox spacing="0.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="0.0" right="0.0" bottom="0.0" left="0.0"/>
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="18.0" styleClass="topbar-shell">
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <ImageView fitHeight="34.0" fitWidth="34.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@/org/example/images/logo.png"/>
                        </image>
                    </ImageView>
                    <Label styleClass="brand-title" text="Bekri"/>
                </HBox>
                <VBox alignment="CENTER_LEFT" spacing="2.0">
                    <Label styleClass="screen-title" text="Post Details"/>
                    <Label styleClass="screen-subtitle" text="Single publication view"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button onAction="#handleBackToDashboard" styleClass="topbar-button" text="Dashboard"/>
                <Button onAction="#handleBackToPosts" styleClass="topbar-button" text="Back To Posts"/>
                <Button onAction="#handleOpenComments" styleClass="primary-button" text="Go To Comments"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="16.0">
            <padding>
                <Insets top="16.0" right="24.0" bottom="24.0" left="24.0"/>
            </padding>
            <HBox spacing="12.0">
                <VBox spacing="6.0">
                    <Label styleClass="section-label" text="Logged-in User"/>
                    <ComboBox fx:id="currentUserComboBox" prefWidth="260.0"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="likeButton" onAction="#handleToggleLike" styleClass="secondary-button" text="Like"/>
                <Button fx:id="saveButton" onAction="#handleToggleSave" styleClass="secondary-button" text="Save"/>
                <Button fx:id="editPostButton" disable="true" onAction="#handleEditPost" styleClass="ghost-button" text="Edit Post"/>
                <Button fx:id="deletePostButton" disable="true" onAction="#handleDeletePost" styleClass="danger-button" text="Delete Post"/>
            </HBox>
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS">
                <content>
                    <VBox spacing="14.0" styleClass="detail-card">
                        <padding>
                            <Insets top="18.0" right="18.0" bottom="18.0" left="18.0"/>
                        </padding>
                        <Label fx:id="selectedPostTitleLabel" styleClass="detail-title" text="Select a post"/>
                        <Label fx:id="selectedPostMetaLabel" styleClass="muted-label" text="Post details"/>
                        <HBox spacing="8.0">
                            <Label fx:id="selectedPostCategoryLabel" styleClass="pill-label pill-neutral" text="No category"/>
                            <Label fx:id="selectedPostStatsLabel" styleClass="muted-label" text="0 likes - 0 comments"/>
                        </HBox>
                        <Label fx:id="selectedPostRiskLabel" styleClass="risk-label" text="Risk: n/a"/>
                        <ImageView fx:id="postImageView" fitHeight="260.0" fitWidth="520.0" pickOnBounds="true" preserveRatio="true"/>
                        <Separator/>
                        <Label fx:id="selectedPostContentLabel" styleClass="detail-content" text="Post content" wrapText="true"/>
                    </VBox>
                </content>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
