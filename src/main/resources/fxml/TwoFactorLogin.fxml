<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.user.ui.TwoFactorLoginController"
            prefWidth="760" prefHeight="560"
            styleClass="page-bg">
    <stylesheets>
        <URL value="@../css/bekri.css"/>
    </stylesheets>
    <center>
        <VBox spacing="14" maxWidth="540" styleClass="card">
            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
            <Label text="Vérification à deux facteurs" styleClass="section-title"/>
            <Label text="Saisissez le code à 6 chiffres de votre application d'authentification."/>
            <TextField fx:id="totpCodeField" promptText="000000" prefColumnCount="6"/>
            <Separator/>
            <Hyperlink text="Utiliser un code de secours" onAction="#handleUseBackupCode"/>
            <VBox fx:id="backupCodeContainer" spacing="6" visible="false" managed="false">
                <Label text="Code de secours"/>
                <TextField fx:id="backupCodeField" promptText="abcd1234"/>
            </VBox>
            <Label fx:id="statusLabel"/>
            <HBox spacing="10">
                <Button text="Vérifier" styleClass="btn-primary" onAction="#handleVerify"/>
                <Button text="Annuler" styleClass="btn-secondary" onAction="#handleCancel"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
