<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.user.ui.ForgotPasswordController"
            prefWidth="960" prefHeight="640"
            styleClass="page-bg">
    <stylesheets>
        <URL value="@../css/bekri.css"/>
    </stylesheets>
    <center>
        <VBox alignment="CENTER" spacing="18" styleClass="auth-right-panel">
            <padding><Insets top="48" right="48" bottom="48" left="48"/></padding>

            <VBox styleClass="auth-form-card" spacing="14" maxWidth="520">
                <VBox spacing="4">
                    <Label text="Mot de passe oublié" styleClass="auth-title"/>
                    <Label text="Entrez votre email pour recevoir un lien de réinitialisation."
                           wrapText="true" styleClass="auth-subtitle"/>
                </VBox>
                <Separator/>

                <VBox spacing="8">
                    <TextField fx:id="emailField" promptText="votre@email.com" styleClass="text-field"/>
                    <Label fx:id="emailError" wrapText="true" managed="false" visible="false" styleClass="error-label"/>
                </VBox>

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Button fx:id="sendButton" text="Envoyer le lien" onAction="#handleSend" styleClass="btn-primary"/>
                    <ProgressIndicator fx:id="progressIndicator" maxWidth="22" maxHeight="22" visible="false" managed="false"/>
                </HBox>

                <Label fx:id="statusLabel" wrapText="true" managed="false" visible="false" styleClass="muted"/>

                <Hyperlink fx:id="backToLoginLink" text="← Retour à la connexion" onAction="#goToLogin"/>
            </VBox>
        </VBox>
    </center>
</BorderPane>

