<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.objectif.ui.QuestionsController"
            styleClass="page-bg"
            prefWidth="1100" prefHeight="700">
    <stylesheets>
        <URL value="@../css/bekri.css"/>
    </stylesheets>
    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="16">
            <Button text="← Retour" styleClass="btn-ghost" onAction="#handleBack"/>
            <Label text="Questions d'évaluation" styleClass="top-bar-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="+ Nouvelle question" styleClass="btn-primary" onAction="#handleNewQuestion"/>
        </HBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox spacing="20">
                <padding><Insets top="28" right="36" bottom="28" left="36"/></padding>
                <VBox styleClass="card" spacing="16">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <TextField fx:id="searchField" promptText="Rechercher une question..." styleClass="text-field" HBox.hgrow="ALWAYS"/>
                        <ComboBox fx:id="filterCategory" promptText="Toutes les catégories" styleClass="combo-box" prefWidth="180"/>
                        <Button text="Rechercher" styleClass="btn-primary" onAction="#handleSearch"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT">
                        <Label fx:id="countLabel" text="" styleClass="muted"/>
                    </HBox>
                    <FlowPane fx:id="cardsPane" hgap="16" vgap="16" prefWrapLength="9999"/>
                    <HBox fx:id="paginationBar" alignment="CENTER" spacing="8">
                        <Button fx:id="btnPrev" text="← Précédent" styleClass="btn-ghost" onAction="#handlePrev"/>
                        <Label fx:id="pageLabel" text="Page 1 / 1" styleClass="muted"/>
                        <Button fx:id="btnNext" text="Suivant →" styleClass="btn-ghost" onAction="#handleNext"/>
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>