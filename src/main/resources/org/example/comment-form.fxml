<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14.0" stylesheets="@app.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.CommentFormController">
    <padding>
        <Insets top="20.0" right="22.0" bottom="20.0" left="22.0"/>
    </padding>

    <Label styleClass="dialog-title" text="Comment Form"/>
    <Label styleClass="muted-label" text="This mirrors the Symfony comment modal flow."/>

    <TextArea fx:id="contentArea" prefRowCount="8" promptText="Votre commentaire..." wrapText="true"/>
    <Label fx:id="validationLabel" styleClass="error-label" text=""/>

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Region HBox.hgrow="ALWAYS"/>
        <Button onAction="#handleCancel" styleClass="ghost-button" text="Cancel"/>
        <Button onAction="#handleSave" styleClass="primary-button" text="Save"/>
    </HBox>
</VBox>
