<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.pijavafx.ui.QuestionFormController"
      spacing="0"
      prefWidth="600"
      style="-fx-background-color: white;">

    <!-- ── HEADER ── -->
    <HBox alignment="CENTER_LEFT" spacing="14"
          style="-fx-background-color: white;
                 -fx-border-color: #e8ecf0;
                 -fx-border-width: 0 0 1 0;
                 -fx-padding: 18 28 18 28;">
        <Label text="📋"
               style="-fx-font-size: 20px;
                      -fx-background-color: #e8f8f7;
                      -fx-background-radius: 12;
                      -fx-padding: 8 10 8 10;"/>
        <VBox spacing="2">
            <Label fx:id="formTitle" text="Nouvelle question"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1a2332;"/>
            <Label text="Remplissez tous les champs requis"
                   style="-fx-font-size: 12px; -fx-text-fill: #94a3b8;"/>
        </VBox>
    </HBox>

    <!-- ── BODY ── -->
    <VBox spacing="0" style="-fx-background-color: white; -fx-padding: 28 32 20 32;">

        <!-- Texte -->
        <Label text="Texte de la question *" styleClass="field-label"/>
        <TextArea fx:id="texteField"
                  promptText="Ex : Comment évaluez-vous votre niveau d'énergie ce mois-ci ?"
                  styleClass="field-input"
                  prefRowCount="3"
                  wrapText="true"/>
        <Label fx:id="texteError" styleClass="field-error" text=""/>
        <Region prefHeight="16"/>

        <!-- Catégorie -->
        <Label text="Catégorie *" styleClass="field-label"/>
        <ComboBox fx:id="categoryCombo"
                  promptText="Choisir une catégorie"
                  styleClass="field-input"
                  maxWidth="Infinity"/>
        <Label fx:id="categoryError" styleClass="field-error" text=""/>
        <Region prefHeight="16"/>

        <!-- Divider -->
        <Region style="-fx-background-color: #e8ecf0; -fx-pref-height:1; -fx-min-height:1; -fx-max-height:1;"/>
        <Region prefHeight="16"/>

        <!-- Options header -->
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="Options de réponse *"
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1a2332;"/>
            <Label text="(3 options requises)"
                   style="-fx-font-size: 12px; -fx-text-fill: #94a3b8;"/>
        </HBox>
        <Region prefHeight="12"/>

        <!-- 3 options -->
        <HBox spacing="16">

            <!-- Option 1 -->
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Option 1 *" styleClass="field-label"/>
                <TextField fx:id="option1Field" promptText="Ex : Très bien" styleClass="field-input"/>
                <Label fx:id="option1Error" styleClass="field-error" text=""/>
            </VBox>

            <!-- Option 2 -->
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Option 2 *" styleClass="field-label"/>
                <TextField fx:id="option2Field" promptText="Ex : Correctement" styleClass="field-input"/>
                <Label fx:id="option2Error" styleClass="field-error" text=""/>
            </VBox>

            <!-- Option 3 -->
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Option 3 *" styleClass="field-label"/>
                <TextField fx:id="option3Field" promptText="Ex : Pas bien du tout" styleClass="field-input"/>
                <Label fx:id="option3Error" styleClass="field-error" text=""/>
            </VBox>

        </HBox>
        <Region prefHeight="8"/>

    </VBox>

    <!-- ── FOOTER ── -->
    <HBox alignment="CENTER_RIGHT" spacing="12"
          style="-fx-background-color: white;
                 -fx-border-color: #e8ecf0;
                 -fx-border-width: 1 0 0 0;
                 -fx-padding: 16 28 16 28;">
        <Button text="Annuler"        onAction="#handleCancel" styleClass="btn-cancel"/>
        <Button text="💾  Enregistrer" onAction="#handleSave"   styleClass="btn-primary"/>
    </HBox>

</VBox>
