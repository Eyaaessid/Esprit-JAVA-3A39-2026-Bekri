<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.pijavafx.ui.QuestionsController"
      styleClass="content-area"
      spacing="0">

    <!-- ── PAGE HEADER ── -->
    <VBox styleClass="page-header" spacing="6">
        <padding><Insets top="36" right="40" bottom="28" left="40"/></padding>
        <Label text="●  SUIVI" styleClass="page-tag" maxWidth="-Infinity"/>
        <HBox alignment="CENTER_LEFT">
            <VBox HBox.hgrow="ALWAYS" spacing="4">
                <Label text="Questions d'évaluation" styleClass="page-title"/>
                <Label text="Créez et gérez les questions posées aux utilisateurs" styleClass="page-subtitle"/>
            </VBox>
            <Button text="+ Nouvelle question" styleClass="btn-primary" onAction="#handleNewQuestion"/>
        </HBox>
    </VBox>

    <!-- ── SCROLLABLE CONTENT ── -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-area">
        <padding><Insets top="28" right="32" bottom="32" left="32"/></padding>

        <VBox spacing="20">

            <!-- Toolbar -->
            <HBox styleClass="toolbar" alignment="CENTER_LEFT" spacing="10">
                <TextField fx:id="searchField"
                           promptText="Rechercher une question..."
                           styleClass="search-field"
                           HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="filterCategory"
                          promptText="Toutes les catégories"
                          styleClass="form-input"
                          prefWidth="180"/>
                <Button text="Rechercher" styleClass="btn-primary" onAction="#handleSearch"/>
            </HBox>

            <!-- Count label -->
            <HBox alignment="CENTER_LEFT">
                <Label fx:id="countLabel" text="" styleClass="card-sub"/>
            </HBox>

            <!-- Cards — FlowPane fills rows evenly, no empty gap -->
            <FlowPane fx:id="cardsPane"
                      hgap="20" vgap="20"
                      prefWrapLength="9999"/>

            <!-- Pagination bar -->
            <HBox fx:id="paginationBar" alignment="CENTER" spacing="8"
                  style="-fx-padding: 4 0 0 0;">
                <Button fx:id="btnPrev" text="← Précédent"
                        styleClass="btn-cancel" onAction="#handlePrev"/>
                <Label fx:id="pageLabel" text="Page 1 / 1"
                       style="-fx-font-size:13px; -fx-text-fill:#64748b; -fx-font-weight:bold; -fx-padding: 0 16 0 16;"/>
                <Button fx:id="btnNext" text="Suivant →"
                        styleClass="btn-cancel" onAction="#handleNext"/>
            </HBox>

        </VBox>
    </ScrollPane>

</VBox>